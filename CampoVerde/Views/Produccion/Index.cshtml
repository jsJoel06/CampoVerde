@model IEnumerable<CampoVerde.Models.Produccion>
@using CampoVerde.Models

@{
    ViewData["Title"] = "Producción";

    var rol = Context.Session.GetString("Rol");


    bool puedeCrear =
        rol == EstadoRol.SUPER_ADMINISTRADOR.ToString() ||
        rol == EstadoRol.ADMINISTRADOR.ToString() ||
        rol == EstadoRol.OPERARIO.ToString();


    bool puedeEditar =
        rol == EstadoRol.SUPER_ADMINISTRADOR.ToString() ||
        rol == EstadoRol.ADMINISTRADOR.ToString() ||
        rol == EstadoRol.VETERINARIO.ToString();


    bool puedeEliminar =
        rol == EstadoRol.SUPER_ADMINISTRADOR.ToString() ||
        rol == EstadoRol.ADMINISTRADOR.ToString();



    // ==========================
    // FECHAS
    // ==========================

    var hoy = DateTime.Today;


    var inicioSemana = hoy.AddDays(
        -(int)hoy.DayOfWeek + 1
    );


    var inicioMes = new DateTime(
        hoy.Year,
        hoy.Month,
        1
    );



    // ==========================
    // PRODUCCIÓN
    // ==========================


    // Total histórico

    var totalLeche = Model
        .Sum(x => x.cantidadLeche);



    // Producción del día

    var produccionDia = Model
        .Where(x =>
            x.fechaProduccion.Date == hoy)
        .Sum(x => x.cantidadLeche);



    // Producción semanal

    var produccionSemana = Model
        .Where(x =>
            x.fechaProduccion.Date >= inicioSemana &&
            x.fechaProduccion.Date <= hoy)
        .Sum(x => x.cantidadLeche);




    // Producción mensual

    var produccionMes = Model
        .Where(x =>
            x.fechaProduccion.Month == hoy.Month &&
            x.fechaProduccion.Year == hoy.Year)
        .Sum(x => x.cantidadLeche);





    // Cantidad de registros

    var totalRegistros = Model.Count();





    // Promedio por registro

    var promedioLeche =
        totalRegistros > 0
        ? totalLeche / totalRegistros
        : 0;




    // Animales productivos

    var totalAnimales = Model
        .Select(x => x.IdAnimal)
        .Distinct()
        .Count();



    // Última producción registrada

    var ultimaProduccion = Model
        .OrderByDescending(x => x.fechaProduccion)
        .FirstOrDefault();

}



<style>

    body {
        background: #eaf2e9;
        font-family: 'Segoe UI',sans-serif;
    }

    h1, h2, h3, h4, h5 {
        color: #1a3c1a;
        font-family: Georgia,serif;
        font-weight: 700;
    }

    .card-estadistica {
        background: linear-gradient(135deg,#4a7c4a,#1a3c1a);
        color: white;
        border: none;
        border-radius: 25px;
        box-shadow: 0 10px 25px rgba(74,124,74,.15);
    }

        .card-estadistica h5,
        .card-estadistica h2,
        .card-estadistica i {
            color: white;
        }

    .card-resumen {
        background: #fdfdf5;
        border-radius: 30px;
        border: 1px solid #d4e0d4;
        box-shadow: 0 10px 30px rgba(74,124,74,.08);
    }

    .card-produccion {
        background: #fdfdf5;
        border-radius: 25px;
        border: 1px solid #d4e0d4;
        box-shadow: 0 10px 25px rgba(74,124,74,.08);
        transition: .3s;
    }

        .card-produccion:hover {
            transform: translateY(-6px);
            box-shadow: 0 18px 35px rgba(74,124,74,.15);
        }

    .btn-verde {
        background: #1a3c1a;
        color: white;
        border-radius: 50px;
        padding: 12px 30px;
        font-weight: bold;
    }

        .btn-verde:hover {
            background: #3d663d;
            color: white;
        }

    .btn {
        border-radius: 50px;
    }

    .progress {
        height: 8px;
        border-radius: 20px;
    }

    .progress-bar {
        border-radius: 20px;
    }

</style>

<div class="container py-5">

    <!-- ENCABEZADO -->

    <div class="d-flex justify-content-between align-items-center mb-5">

        <div>

            <h1>

                🐄 Producción de Leche

            </h1>

            <p class="text-muted">

                Administración y seguimiento diario de la producción.

            </p>

        </div>

        <div class="d-flex gap-2">

            <a asp-action="Historial"
               class="btn btn-outline-success">

                <i class="bi bi-clock-history me-2"></i>

                Historial

            </a>

            @if (puedeCrear)
            {
                <a asp-action="Create"
                   class="btn btn-verde">

                    <i class="bi bi-plus-circle me-2"></i>

                    Nueva Producción

                </a>
            }

        </div>

    </div>

    <!-- FILTROS -->

    <div class="d-flex justify-content-center gap-3 mb-5">


        <a asp-action="Index"
           asp-route-filtro="hoy"
           class="btn btn-success">

            <i class="bi bi-calendar-day"></i>
            Hoy

        </a>



        <a asp-action="Index"
           asp-route-filtro="semana"
           class="btn btn-success">

            <i class="bi bi-calendar-week"></i>
            Semana

        </a>



        <a asp-action="Index"
           asp-route-filtro="mes"
           class="btn btn-success">

            <i class="bi bi-calendar-month"></i>
            Mes

        </a>



        <a asp-action="Index"
           asp-route-filtro="total"
           class="btn btn-outline-success">

            <i class="bi bi-list"></i>
            Todo

        </a>


    </div>




    <!-- ESTADÍSTICAS -->

    <div class="row g-4 mb-5">


        <div class="col-md-6 col-lg-3">

            <div class="card card-estadistica">

                <div class="card-body text-center">

                    <i class="bi bi-droplet-half display-4"></i>

                    <h5 class="mt-3">
                        Producción
                    </h5>

                    <h2>
                        @ViewBag.TotalProduccion.ToString("N1") L
                    </h2>

                </div>

            </div>

        </div>




        <div class="col-md-6 col-lg-3">

            <div class="card card-estadistica">

                <div class="card-body text-center">

                    <i class="bi bi-journal-check display-4"></i>

                    <h5 class="mt-3">
                        Registros
                    </h5>

                    <h2>
                        @ViewBag.TotalRegistros
                    </h2>

                </div>

            </div>

        </div>




        <div class="col-md-6 col-lg-3">

            <div class="card card-estadistica">

                <div class="card-body text-center">

                    <i class="bi bi-graph-up-arrow display-4"></i>

                    <h5 class="mt-3">
                        Promedio
                    </h5>

                    <h2>
                        @ViewBag.Promedio.ToString("N1") L
                    </h2>

                </div>

            </div>

        </div>




        <div class="col-md-6 col-lg-3">

            <div class="card card-estadistica">

                <div class="card-body text-center">

                    <i class="bi bi-cow display-4"></i>

                    <h5 class="mt-3">
                        Animales
                    </h5>

                    <h2>
                        @ViewBag.TotalAnimales
                    </h2>

                </div>

            </div>

        </div>


    </div>

    <!-- TARJETAS -->

    <div class="row g-4">

        @if (!Model.Any())
        {
            <div class="col-12">

                <div class="card card-resumen text-center py-5">

                    <div class="card-body">

                        <i class="bi bi-droplet display-1 text-success"></i>

                        <h3 class="mt-4">

                            No hay registros de producción

                        </h3>

                        <p class="text-muted mb-4">

                            Aún no se ha registrado ninguna producción de leche.

                        </p>

                        @if (puedeCrear)
                        {
                            <a asp-action="Create"
                               class="btn btn-verde">

                                <i class="bi bi-plus-circle me-2"></i>

                                Registrar Primera Producción

                            </a>
                        }

                    </div>

                </div>

            </div>
        }
        else
        {

            @foreach (var item in Model.OrderByDescending(x => x.fechaProduccion))
            {

                <div class="col-md-6 col-lg-4">

                    <div class="card card-produccion h-100">

                        <div class="card-header bg-success text-white border-0">

                            <div class="d-flex justify-content-between align-items-center">

                                <div>

                                    <h5 class="mb-1">

                                        🐄 @(item.Animal?.nombre ?? "Animal")

                                    </h5>

                                    <small>

                                        <i class="bi bi-calendar-event"></i>

                                        @item.fechaProduccion.ToString("dd/MM/yyyy")

                                    </small>

                                </div>

                                <div>

                                    <span class="badge bg-light text-success fs-6">

                                        @item.Turno

                                    </span>

                                </div>

                            </div>

                        </div>

                        <div class="card-body">

                            <div class="text-center mb-3">

                                <h2 class="text-success fw-bold">

                                    🥛 @item.cantidadLeche.ToString("N1") L

                                </h2>

                            </div>

                            <div class="progress mb-3">

                                <div class="progress-bar bg-success"
                                     role="progressbar"
                                     style="width:@Math.Min(item.cantidadLeche * 5,100)%">
                                </div>

                            </div>

                            <div class="row text-center">

                                <div class="col-6">

                                    <small class="text-muted">

                                        Fecha

                                    </small>

                                    <div class="fw-bold">

                                        @item.fechaProduccion.ToString("dd/MM")

                                    </div>

                                </div>

                                <div class="col-6">

                                    <small class="text-muted">

                                        Turno

                                    </small>

                                    <div class="fw-bold text-success">

                                        @item.Turno

                                    </div>

                                </div>

                            </div>

                            @if (!string.IsNullOrWhiteSpace(item.observaciones))
                            {

                                <hr />

                                <small class="text-muted">

                                    Observaciones

                                </small>

                                <p class="mb-0">

                                    @item.observaciones

                                </p>

                            }

                        </div>

                        <div class="card-footer bg-white border-0">

                            <div class="d-grid gap-2">

                                <a asp-action="Details"
                                   asp-route-id="@item.IdProduccion"
                                   class="btn btn-outline-primary">

                                    <i class="bi bi-eye me-2"></i>

                                    Ver Detalles

                                </a>

                                @if (puedeEditar)
                                {

                                    <a asp-action="Edit"
                                       asp-route-id="@item.IdProduccion"
                                       class="btn btn-outline-success">

                                        <i class="bi bi-pencil-square me-2"></i>

                                        Editar

                                    </a>

                                }

                                @if (puedeEliminar)
                                {

                                    <a asp-action="Delete"
                                       asp-route-id="@item.IdProduccion"
                                       class="btn btn-outline-danger">

                                        <i class="bi bi-trash me-2"></i>

                                        Eliminar

                                    </a>

                                }

                            </div>

                        </div>

                    </div>

                </div>

            }

        }
    </div>

</div>

@section Scripts {

    <script>

        document.addEventListener("DOMContentLoaded", function () {

            // Animación suave de las tarjetas
            const cards = document.querySelectorAll(".card-produccion");

            cards.forEach((card, index) => {

                card.style.opacity = "0";
                card.style.transform = "translateY(25px)";

                setTimeout(() => {

                    card.style.transition = "all .4s ease";
                    card.style.opacity = "1";
                    card.style.transform = "translateY(0)";

                }, index * 80);

            });

        });

    </script>

}
@model IEnumerable<CampoVerde.Models.Produccion>

@{
    ViewData["Title"] = "Historial de Producción";

    var totalLeche = Model.Sum(x => x.cantidadLeche);
    var totalRegistros = Model.Count();
    var promedio = totalRegistros > 0 ? totalLeche / totalRegistros : 0;
}

<style>

    body {
        background: #eef5ef;
    }

    .page-title {
        color: #2e7d32;
        font-weight: 700;
    }

    .card-stat {
        border: none;
        border-radius: 18px;
        background: linear-gradient(135deg,#2e7d32,#43a047);
        color: white;
        box-shadow: 0 10px 25px rgba(0,0,0,.12);
    }

    .card-table {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 25px rgba(0,0,0,.08);
    }

    .table thead {
        background: #2e7d32;
        color: white;
    }

    .table tbody tr {
        transition: .25s;
    }

        .table tbody tr:hover {
            background: #f4fff4;
            transform: scale(1.005);
        }

    .badge-turno {
        background: #43a047;
        font-size: .9rem;
        padding: 8px 14px;
        border-radius: 20px;
    }

    .btn-regresar {
        border-radius: 30px;
    }

    .search-box {
        border-radius: 30px;
    }

</style>

<div class="container py-5">

    <!-- ENCABEZADO -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="page-title">
                <i class="bi bi-clock-history"></i>
                Historial de Producción
            </h2>

            <p class="text-muted mb-0">
                Consulta todas las producciones registradas.
            </p>

        </div>

        <a asp-action="Index" class="btn btn-success btn-regresar">
            <i class="bi bi-arrow-left"></i>
            Volver
        </a>

    </div>

    <!-- ESTADÍSTICAS -->
    <div class="row g-4 mb-4">

        <div class="col-md-4">

            <div class="card card-stat">

                <div class="card-body text-center">

                    <i class="bi bi-droplet-half display-4"></i>

                    <h5 class="mt-3">Total Leche</h5>

                    <h2>@totalLeche.ToString("N1") L</h2>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card card-stat">

                <div class="card-body text-center">

                    <i class="bi bi-list-check display-4"></i>

                    <h5 class="mt-3">Registros</h5>

                    <h2>@totalRegistros</h2>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card card-stat">

                <div class="card-body text-center">

                    <i class="bi bi-graph-up display-4"></i>

                    <h5 class="mt-3">Promedio</h5>

                    <h2>@promedio.ToString("N1") L</h2>

                </div>

            </div>

        </div>

    </div>

    <!-- BUSCADOR -->

    <div class="card card-table mb-4">

        <div class="card-body">

            <div class="input-group">

                <span class="input-group-text bg-success text-white">
                    <i class="bi bi-search"></i>
                </span>

                <input type="text"
                       id="buscar"
                       class="form-control search-box"
                       placeholder="Buscar por animal, código, turno...">

            </div>

        </div>

    </div>

    <!-- TABLA -->

    <div class="card card-table">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0" id="tablaHistorial">

                <thead>

                    <tr>

                        <th>Fecha</th>
                        <th>Animal</th>
                        <th>Código</th>
                        <th>Leche</th>
                        <th>Turno</th>
                        <th>Observaciones</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model.OrderByDescending(x => x.fechaProduccion))
                    {
                        <tr>

                            <td>
                                @item.fechaProduccion.ToString("dd/MM/yyyy")
                            </td>

                            <td>
                                🐄 <strong>@item.Animal?.nombre</strong>
                            </td>

                            <td>
                                @item.Animal?.codigo
                            </td>

                            <td>

                                <span class="fw-bold text-success">
                                    🥛 @item.cantidadLeche L
                                </span>

                            </td>

                            <td>

                                <span class="badge badge-turno">
                                    @item.Turno
                                </span>

                            </td>

                            <td>

                                @if (string.IsNullOrWhiteSpace(item.observaciones))
                                {
                                    <span class="text-muted">
                                        Sin observaciones
                                    </span>
                                }
                                else
                                {
                                    @item.observaciones
                                }

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

<script>

    document.getElementById("buscar").addEventListener("keyup", function () {

        let texto = this.value.toLowerCase();

        let filas = document.querySelectorAll("#tablaHistorial tbody tr");

        filas.forEach(function(fila){

            fila.style.display =
                fila.innerText.toLowerCase().includes(texto)
                ? ""
                : "none";

        });

    });

</script>
@model CampoVerde.Models.Produccion

@{
    ViewData["Title"] = "Eliminar Producción";
}

<style>

    body {
        background: #eaf2e9;
    }

    .delete-header {
        background: linear-gradient(135deg, #c62828, #e53935);
        color: white;
        padding: 35px;
        border-radius: 20px;
        box-shadow: 0 8px 20px rgba(0,0,0,.12);
    }

    .info-box {
        background: rgba(255,255,255,.65);
        backdrop-filter: blur(8px);
        border-left: 5px solid #43a047;
        border-radius: 15px;
        padding: 18px;
        margin-bottom: 18px;
        transition: .3s;
    }

        .info-box:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(46,125,50,.12);
        }

    .valor {
        font-size: 20px;
        font-weight: 700;
        color: #2e7d32;
        margin-top: 5px;
    }

    .btn-delete {
        background: #d32f2f;
        color: white;
        border: none;
        border-radius: 10px;
        padding: 12px 35px;
        transition: .3s;
    }

        .btn-delete:hover {
            background: #b71c1c;
            color: white;
            transform: translateY(-2px);
        }

    .btn-cancel {
        border-radius: 10px;
        padding: 12px 35px;
    }

</style>

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <!-- ENCABEZADO -->

            <div class="delete-header text-center mb-4">

                <h1 class="fw-bold mb-2">
                    🗑️ Eliminar Producción
                </h1>

                <p class="mb-0">
                    Esta acción eliminará permanentemente el registro.
                </p>

            </div>

            <!-- MENSAJE -->

            <div class="alert alert-warning shadow-sm rounded-3">

                <h5 class="mb-1">
                    ⚠ ¿Deseas continuar?
                </h5>

                <small>
                    Una vez eliminado el registro no podrá recuperarse.
                </small>

            </div>

            <!-- INFORMACIÓN -->

            <div class="info-box">

                <small class="text-muted">
                    Animal
                </small>

                <div class="valor">
                    🐄 @Model.Animal?.nombre
                </div>

            </div>

            <div class="info-box">

                <small class="text-muted">
                    Cantidad de leche
                </small>

                <div class="valor">
                    🥛 @Model.cantidadLeche L
                </div>

            </div>

            <div class="info-box">

                <small class="text-muted">
                    Turno
                </small>

                <div class="valor">
                    🕒 @Model.Turno
                </div>

            </div>

            <div class="info-box">

                <small class="text-muted">
                    Fecha
                </small>

                <div class="valor">
                    📅 @Model.fechaProduccion.ToString("dd/MM/yyyy")
                </div>

            </div>

            @if (!string.IsNullOrWhiteSpace(Model.observaciones))
            {
                <div class="info-box">

                    <small class="text-muted">
                        Observaciones
                    </small>

                    <div class="mt-2">
                        @Model.observaciones
                    </div>

                </div>
            }

            <!-- FORMULARIO -->

            <form asp-action="Delete" class="mt-5">

                <input type="hidden" asp-for="IdProduccion" />

                <div class="d-flex justify-content-between">

                    <a asp-action="Index"
                       class="btn btn-outline-secondary btn-lg btn-cancel">

                        <i class="bi bi-arrow-left me-2"></i>

                        Cancelar

                    </a>

                    <button type="submit"
                            class="btn btn-delete btn-lg">

                        <i class="bi bi-trash-fill me-2"></i>

                        Eliminar Registro

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>
@model CampoVerde.Models.Gasto
@using CampoVerde.Models

@{
    ViewData["Title"] = "Detalles del Gasto";

    var rol = Context.Session.GetString("Rol");

    bool puedeEditar =
        rol == EstadoRol.SUPER_ADMINISTRADOR.ToString() ||
        rol == EstadoRol.ADMINISTRADOR.ToString();
}


<style>

    body {
        background-color: #eaf2e9;
        font-family: 'Segoe UI', sans-serif;
    }


    .card-ganaderia {
        background-color: #fdfdf5;
        border-radius: 30px;
        border: 1px solid #d4e0d4;
        box-shadow: 0 10px 30px rgba(74,124,74,.12);
        padding: 40px;
    }


    .icon-box {
        width: 70px;
        height: 70px;
        border-radius: 25px;
        background: #d4e0d4;
        color: #1a3c1a;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 30px;
    }


    h2 {
        color: #1a3c1a;
        font-family: Georgia,serif;
        font-weight: 700;
    }


    .info-card {
        background: white;
        border-radius: 20px;
        padding: 20px;
        border: 1px solid #e1e8df;
    }


    .label {
        color: #7a907a;
        font-size: .75rem;
        text-transform: uppercase;
        font-weight: bold;
    }


    .valor {
        color: #1a3c1a;
        font-size: 1.1rem;
        font-weight: 600;
    }


    .btn-verde {
        background: #1a3c1a;
        color: white;
        border-radius: 50px;
        padding: 12px 30px;
        font-weight: bold;
    }


        .btn-verde:hover {
            background: #3d663d;
            color: white;
        }


    .btn-outline {
        border-radius: 50px;
        padding: 12px 30px;
    }

</style>



<div class="container py-5">


    <div class="card-ganaderia">


        <div class="d-flex align-items-center mb-4">


            <div class="icon-box me-3">

                <i class="fa-solid fa-wallet"></i>

            </div>


            <div>

                <h2 class="mb-1">
                    Detalles del Gasto
                </h2>

                <p class="text-muted mb-0">
                    Información completa del registro financiero
                </p>

            </div>


        </div>



        <hr />



        <div class="row g-4">


            <div class="col-md-6">

                <div class="info-card">

                    <div class="label">
                        Concepto
                    </div>

                    <div class="valor">
                        @Model.Concepto
                    </div>

                </div>

            </div>




            <div class="col-md-6">

                <div class="info-card">

                    <div class="label">
                        Monto
                    </div>

                    <div class="valor text-danger">

                        @Model.Monto.ToString("C2")

                    </div>

                </div>

            </div>





            <div class="col-md-6">

                <div class="info-card">

                    <div class="label">
                        Fecha
                    </div>

                    <div class="valor">

                        @Model.Fecha.ToString("dd/MM/yyyy")

                    </div>

                </div>

            </div>





            <div class="col-md-6">

                <div class="info-card">

                    <div class="label">
                        Categoría
                    </div>

                    <div class="valor">

                        <span class="badge bg-success">

                            @Model.Categoria

                        </span>

                    </div>

                </div>

            </div>






            <div class="col-md-6">

                <div class="info-card">


                    <div class="label">
                        Animal Asociado
                    </div>


                    <div class="valor">

                        @(Model.Animal?.nombre ?? "Sin animal asociado")

                    </div>


                </div>


            </div>







            <div class="col-md-6">


                <div class="info-card">


                    <div class="label">
                        Id Gasto
                    </div>


                    <div class="valor">

                        #@Model.IdGasto

                    </div>


                </div>


            </div>






            <div class="col-12">


                <div class="info-card">


                    <div class="label">
                        Notas
                    </div>


                    <div class="valor">

                        @(string.IsNullOrEmpty(Model.Notas)
                        ? "Sin notas registradas"
                        : Model.Notas)

                    </div>


                </div>


            </div>



        </div>





        <div class="mt-5 d-flex justify-content-end gap-3">


            @if (puedeEditar)
            {

                <a asp-action="Edit"
                   asp-route-id="@Model.IdGasto"
                   class="btn btn-verde">

                    <i class="fa-solid fa-pen me-2"></i>

                    Editar

                </a>

            }



            <a asp-action="Index"
               class="btn btn-outline-secondary btn-outline">

                <i class="fa-solid fa-arrow-left me-2"></i>

                Volver

            </a>



        </div>



    </div>


</div>
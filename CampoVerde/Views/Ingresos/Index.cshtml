@model IEnumerable<CampoVerde.Models.Ingreso>
@using CampoVerde.Models

@{
    ViewData["Title"] = "Registro de Ingresos";

    var rol = Context.Session.GetString("Rol");

    bool puedeEditar =
        rol == EstadoRol.SUPER_ADMINISTRADOR.ToString() ||
        rol == EstadoRol.ADMINISTRADOR.ToString();


    decimal totalIngresos = Model.Sum(x => x.Monto);
}


<style>

    body {
        background-color: #eaf2e9;
        font-family: 'Segoe UI',sans-serif;
    }


    .card-ganaderia {
        background: #fdfdf5;
        border-radius: 30px;
        padding: 40px;
        border: 1px solid #d4e0d4;
        box-shadow: 0 10px 30px rgba(74,124,74,.12);
    }



    h2 {
        color: #1a3c1a;
        font-family: Georgia,serif;
        font-weight: 700;
    }



    .resumen {
        background: linear-gradient(135deg,#4a7c4a,#1a3c1a);
        color: white;
        border-radius: 25px;
        padding: 25px;
    }



        .resumen h3 {
            color: white;
            font-size: 2rem;
        }



    .btn-verde {
        background: #1a3c1a;
        color: white;
        border-radius: 50px;
        padding: 12px 30px;
        font-weight: bold;
        text-decoration: none;
    }


        .btn-verde:hover {
            background: #3d663d;
            color: white;
        }



    .table {
        border-collapse: separate;
        border-spacing: 0 12px;
    }



        .table thead th {
            background: #d4e0d4;
            color: #1a3c1a;
            border: none;
            padding: 15px;
        }



        .table tbody tr {
            background: white;
            box-shadow: 0 5px 15px rgba(0,0,0,.04);
        }



        .table tbody td {
            padding: 18px;
            vertical-align: middle;
        }



    .badge-animal {
        background: #eaf2e9;
        color: #1a3c1a;
        padding: 7px 18px;
        border-radius: 50px;
        border: 1px solid #c8d9c8;
    }



    .btn-action {
        width: 35px;
        height: 35px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

</style>




<div class="container py-5">



    <div class="row mb-4">


        <div class="col-md-4">

            <div class="resumen">


                <small>
                    Total Ingresos
                </small>


                <h3 class="mb-0">

                    @totalIngresos.ToString("C2")

                </h3>


            </div>


        </div>


    </div>






    <div class="card-ganaderia">


        <div class="d-flex justify-content-between align-items-center mb-4">


            <div>

                <h2>

                    <i class="fa-solid fa-money-bill-trend-up me-2"></i>

                    Registro de Ventas

                </h2>


                <p class="text-muted">
                    Control de ingresos generados por la ganadería
                </p>


            </div>




            @if (puedeEditar)
            {

                <a asp-action="AddForm"
                   class="btn-verde">

                    <i class="fa-solid fa-plus me-2"></i>

                    Nueva Venta

                </a>

            }



        </div>







        <div class="table-responsive">


            <table class="table text-center align-middle">


                <thead>

                    <tr>

                        <th>
                            Fecha
                        </th>

                        <th>
                            Concepto
                        </th>

                        <th>
                            Animal
                        </th>

                        <th>
                            Monto
                        </th>

                        <th>
                            Acciones
                        </th>

                    </tr>

                </thead>



                <tbody>


                    @if (Model.Any())
                    {


                        foreach (var item in Model)
                        {


                            <tr>


                                <td class="fw-bold">

                                    @item.Fecha.ToString("dd/MM/yyyy")

                                </td>



                                <td>

                                    @item.Concepto

                                </td>




                                <td>


                                    <span class="badge-animal">

                                        @(item.Animal?.nombre ?? "General")

                                    </span>


                                </td>





                                <td class="text-success fw-bold">


                                    @item.Monto.ToString("C2")


                                </td>





                                <td>


                                    <div class="d-flex justify-content-center gap-2">



                                        <a asp-action="Details"
                                           asp-route-id="@item.IdIngreso"
                                           class="btn btn-outline-info btn-action">

                                            <i class="fa-solid fa-eye"></i>

                                        </a>





                                        @if (item.IdAnimal.HasValue)
                                        {

                                            <a asp-action="Historial"
                                               asp-route-idAnimal="@item.IdAnimal"
                                               class="btn btn-outline-secondary btn-action">

                                                <i class="fa-solid fa-clock-rotate-left"></i>

                                            </a>

                                        }





                                        @if (puedeEditar)
                                        {


                                            <a asp-action="AddForm"
                                               asp-route-id="@item.IdIngreso"
                                               class="btn btn-outline-warning btn-action">

                                                <i class="fa-solid fa-pen"></i>

                                            </a>





                                            <form asp-action="Delete"
                                                  asp-route-id="@item.IdIngreso"
                                                  method="post"
                                                  class="d-inline">


                                                @Html.AntiForgeryToken()


                                                <button type="submit"
                                                        class="btn btn-outline-danger btn-action"
                                                        onclick="return confirm('¿Desea eliminar este ingreso?')">


                                                    <i class="fa-solid fa-trash"></i>


                                                </button>


                                            </form>


                                        }



                                    </div>



                                </td>



                            </tr>



                        }



                    }
                    else
                    {


                        <tr>

                            <td colspan="5"
                                class="text-center text-muted py-4">


                                No existen ingresos registrados.


                            </td>

                        </tr>


                    }


                </tbody>


            </table>


        </div>



    </div>



</div>
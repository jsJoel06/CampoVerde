@model CampoVerde.Models.Usuario

@{
    ViewData["Title"] = "Crear Cuenta";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <style>

            :root {
                --primary: #2d5a27;
                --secondary: #5c9a5c;
                --dark: #1a3c1a;
                --light: #fdfdf5;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Inter',sans-serif;
            }

            body {
                background: linear-gradient(rgba(18,45,18,.82), rgba(18,45,18,.82)), url("https://images.unsplash.com/photo-1500595046743-cd271d694d30?auto=format&fit=crop&w=1800&q=80");
                background-size: cover;
                background-position: center;
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                padding: 30px;
            }

            .register-container {
                width: 100%;
                max-width: 1050px;
                display: flex;
                overflow: hidden;
                border-radius: 30px;
                background: white;
                box-shadow: 0 25px 60px rgba(0,0,0,.25);
            }

            .left-side {
                width: 45%;
                background: linear-gradient(150deg,var(--primary),var(--dark));
                color: white;
                padding: 60px;
                display: flex;
                flex-direction: column;
                justify-content: center;
            }

                .left-side i {
                    font-size: 70px;
                    margin-bottom: 30px;
                    opacity: .85;
                }

                .left-side h1 {
                    font-size: 42px;
                    font-weight: 700;
                    margin-bottom: 20px;
                }

                .left-side p {
                    font-size: 17px;
                    opacity: .85;
                    line-height: 1.8;
                }

            .right-side {
                width: 55%;
                padding: 50px;
            }

            h2 {
                color: var(--dark);
                font-weight: 700;
            }

            .subtitle {
                color: #777;
                margin-bottom: 35px;
            }

            .form-control {
                border-radius: 15px;
                padding: 14px;
                border: 2px solid #e8e8e8;
            }

                .form-control:focus {
                    border-color: var(--primary);
                    box-shadow: none;
                }

            .input-group-text {
                border-radius: 15px 0 0 15px;
                border: 2px solid #e8e8e8;
                border-right: none;
                background: #f8f9fa;
            }

            .input-group .form-control {
                border-left: none;
            }

            .btn-register {
                height: 52px;
                border: none;
                border-radius: 15px;
                background: var(--primary);
                color: white;
                font-weight: 600;
                transition: .3s;
            }

                .btn-register:hover {
                    background: var(--dark);
                    transform: translateY(-2px);
                }

            .login-link {
                text-align: center;
                margin-top: 25px;
            }

                .login-link a {
                    text-decoration: none;
                    color: var(--primary);
                    font-weight: 600;
                }

                    .login-link a:hover {
                        color: var(--dark);
                    }

            @@media(max-width:900px) {

                .left-side {
                    display: none;
                }

                .right-side {
                    width: 100%;
                    padding: 35px;
                }

                .register-container {
                    max-width: 550px;
                }
            }

    </style>

</head>

<body>

    <div class="register-container">

        <!-- PANEL IZQUIERDO -->

        <div class="left-side">

            <i class="fa-solid fa-cow"></i>

            <h1>Únete a CampoVerde</h1>

            <p>
                Administra animales, vacunas, producción, ventas,
                gastos y toda la información de tu finca desde
                una única plataforma moderna.
            </p>

        </div>

        <!-- FORMULARIO -->

        <div class="right-side">

            <h2>Crear Cuenta</h2>

            <p class="subtitle">
                Completa la información para registrarte.
            </p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    <i class="fa-solid fa-circle-exclamation me-2"></i>
                    @ViewBag.Error
                </div>
            }

            <form asp-action="Register" method="post">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <div class="mb-3">

                    <label class="fw-semibold mb-2">
                        Nombre
                    </label>

                    <div class="input-group">

                        <span class="input-group-text">
                            <i class="fa-solid fa-user"></i>
                        </span>

                        <input asp-for="nombre"
                               class="form-control"
                               placeholder="Nombre completo" />

                    </div>

                    <span asp-validation-for="nombre"
                          class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label class="fw-semibold mb-2">
                        Correo
                    </label>

                    <div class="input-group">

                        <span class="input-group-text">
                            <i class="fa-solid fa-envelope"></i>
                        </span>

                        <input asp-for="email"
                               class="form-control"
                               placeholder="correo@campoverde.com" />

                    </div>

                    <span asp-validation-for="email"
                          class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label class="fw-semibold mb-2">
                        Teléfono
                    </label>

                    <div class="input-group">

                        <span class="input-group-text">
                            <i class="fa-solid fa-phone"></i>
                        </span>

                        <input asp-for="telefono"
                               class="form-control"
                               placeholder="809-000-0000" />

                    </div>

                </div>

                <div class="mb-4">

                    <label class="fw-semibold mb-2">
                        Contraseña
                    </label>

                    <div class="input-group">

                        <span class="input-group-text">
                            <i class="fa-solid fa-lock"></i>
                        </span>

                        <input asp-for="password"
                               type="password"
                               class="form-control"
                               placeholder="********" />

                    </div>

                    <span asp-validation-for="password"
                          class="text-danger"></span>

                </div>

                <!-- Si el rol lo asigna automáticamente el controlador -->
                <input type="hidden" asp-for="Rol" value="OPERARIO" />

                <button class="btn btn-register w-100">

                    <i class="fa-solid fa-user-plus me-2"></i>

                    Crear Cuenta

                </button>

            </form>

            <div class="login-link">

                ¿Ya tienes una cuenta?

                <br>

                <a asp-action="Login">
                    Iniciar sesión
                </a>

            </div>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>
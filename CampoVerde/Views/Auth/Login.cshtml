@{
    ViewData["Title"] = "Iniciar Sesión | CampoVerde";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <style>

            * {
                font-family: 'Poppins',sans-serif;
            }

            body {
                margin: 0;
                min-height: 100vh;
                background: linear-gradient(rgba(19,55,23,.65), rgba(19,55,23,.65)), url("https://images.unsplash.com/photo-1500595046743-cd271d694d30?auto=format&fit=crop&w=1600&q=80");
                background-size: cover;
                background-position: center;
                display: flex;
                justify-content: center;
                align-items: center;
            }

            .login-card {
                width: 100%;
                max-width: 1100px;
                display: flex;
                background: rgba(255,255,255,.92);
                backdrop-filter: blur(12px);
                border-radius: 30px;
                overflow: hidden;
                box-shadow: 0 25px 60px rgba(0,0,0,.25);
            }

            .left-panel {
                width: 45%;
                background: linear-gradient(160deg,#1a3c1a,#4a7c4a);
                color: white;
                padding: 60px;
                display: flex;
                flex-direction: column;
                justify-content: center;
            }

                .left-panel h1 {
                    font-size: 42px;
                    font-weight: 700;
                }

                .left-panel p {
                    opacity: .9;
                    line-height: 1.8;
                }

                .left-panel i {
                    font-size: 80px;
                    margin-bottom: 30px;
                    color: #d4e0d4;
                }

            .right-panel {
                width: 55%;
                padding: 60px;
            }

            .logo {
                display: flex;
                align-items: center;
                gap: 15px;
                margin-bottom: 30px;
            }

                .logo img {
                    width: 60px;
                    height: 60px;
                    border-radius: 50%;
                    object-fit: cover;
                }

                .logo h2 {
                    color: #1a3c1a;
                    font-weight: 700;
                    margin: 0;
                }

            .form-control {
                border-radius: 15px;
                padding: 14px;
                border: 1px solid #d4e0d4;
            }

                .form-control:focus {
                    border-color: #4a7c4a;
                    box-shadow: 0 0 0 .2rem rgba(74,124,74,.2);
                }

            .input-group-text {
                background: white;
                border-radius: 15px 0 0 15px;
                border-color: #d4e0d4;
            }

            .btn-login {
                background: #1a3c1a;
                color: white;
                border: none;
                border-radius: 50px;
                padding: 14px;
                font-weight: 600;
                transition: .3s;
            }

                .btn-login:hover {
                    background: #3d663d;
                    transform: translateY(-2px);
                }

            .alert {
                border-radius: 15px;
            }

            .copyright {
                font-size: 13px;
                color: #999;
                margin-top: 30px;
                text-align: center;
            }

            @@media(max-width:992px) {

                .left-panel {
                    display: none;
                }

                .right-panel {
                    width: 100%;
                }

                .login-card {
                    margin: 20px;
                }
            }

    </style>

</head>

<body>

    <div class="login-card">

        <!-- PANEL IZQUIERDO -->

        <div class="left-panel">

            <i class="fas fa-cow"></i>

            <h1>CampoVerde</h1>

            <h4 class="mb-4">

                Sistema Inteligente de Gestión Ganadera

            </h4>

            <p>

                Administra animales, producción, vacunas, partos,
                inventario, ingresos y gastos desde un solo lugar.

            </p>

        </div>

        <!-- PANEL DERECHO -->

        <div class="right-panel">

            <div class="logo">

                <img src="~/img/vaca.jpg" asp-append-version="true" />

                <div>

                    <h2>CampoVerde</h2>

                    <small class="text-muted">

                        Plataforma Ganadera

                    </small>

                </div>

            </div>

            <h3 class="fw-bold mb-2">

                Bienvenido

            </h3>

            <p class="text-muted mb-4">

                Inicia sesión para continuar.

            </p>

            @if (ViewBag.Error != null)
            {

                <div class="alert alert-danger">

                    <i class="fas fa-circle-exclamation me-2"></i>

                    @ViewBag.Error

                </div>

            }

            <form asp-action="Login" method="post">

                @Html.AntiForgeryToken()

                <div class="mb-3">

                    <label class="form-label fw-semibold">

                        Correo electrónico

                    </label>

                    <div class="input-group">

                        <span class="input-group-text">

                            <i class="fas fa-envelope"></i>

                        </span>

                        <input type="email"
                               name="email"
                               class="form-control"
                               placeholder="usuario@campoverde.com"
                               required />

                    </div>

                </div>

                <div class="mb-4">

                    <label class="form-label fw-semibold">

                        Contraseña

                    </label>

                    <div class="input-group">

                        <span class="input-group-text">

                            <i class="fas fa-lock"></i>

                        </span>

                        <input id="password"
                               type="password"
                               name="password"
                               class="form-control"
                               placeholder="********"
                               required />

                        <button type="button"
                                class="btn btn-outline-secondary"
                                onclick="mostrarPassword()">

                            <i id="icono" class="fas fa-eye"></i>

                        </button>

                    </div>

                </div>

                <button class="btn btn-login w-100">

                    <i class="fas fa-right-to-bracket me-2"></i>

                    Iniciar Sesión

                </button>

            </form>

            <div class="copyright">

                © @DateTime.Now.Year CampoVerde · Sistema de Gestión Ganadera

            </div>

        </div>

    </div>

    <script>

            function mostrarPassword(){

                let txt=document.getElementById("password");
                let icon=document.getElementById("icono");

                if(txt.type==="password"){

                    txt.type="text";
                    icon.className="fas fa-eye-slash";

                }else{

                    txt.type="password";
                    icon.className="fas fa-eye";

                }

            }

    </script>

</body>

</html>
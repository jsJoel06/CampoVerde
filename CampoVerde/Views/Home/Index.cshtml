

@{
    ViewData["Title"] = "Panel Principal - Ganadería Campo Verde";

    var lista = ViewBag.Potreros as List<CampoVerde.Models.Potrero>
               ?? new List<CampoVerde.Models.Potrero>();

}



<style>
    body { background-color: #eaf2e9; }
    
    .card-dashboard {
        background-color: #fdfdf5;
        border: 1px solid #d4e0d4;
        border-radius: 25px;
        box-shadow: 0 10px 30px rgba(74, 124, 74, 0.05);
        padding: 30px;
        transition: transform 0.3s;
    }

    .card-dashboard:hover { transform: translateY(-5px); }

    .icon-box {
        background-color: #d4e0d4;
        color: #1a3c1a;
        padding: 15px;
        border-radius: 20px;
        width: 55px;
        height: 55px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
    }

    .btn-campo-dark {
        background-color: #1a3c1a;
        color: white;
        border-radius: 50px;
        padding: 12px 30px;
        font-weight: 600;
        transition: 0.3s;
    }

    .btn-campo-dark:hover { background-color: #3d663d; color: white; }
</style>

<div class="container py-5">
    <div class="mb-5">


        <h2 class="fw-bold" style="color: #1a3c1a;">Bienvenido, Joel</h2>
        <p style="color: #3d663d;">Panel central de gestión para Ganadería Campo Verde</p>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card-dashboard h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="text-secondary small text-uppercase fw-bold">Inventario</h5>
                    <div class="icon-box"><i class="fa-solid fa-cow"></i></div>
                </div>
                <h3 class="mt-3 mb-0" style="color: #1a3c1a;">@ViewBag.TotalReses <span class="fs-6 text-muted">reses</span></h3>
                <p class="text-success small mt-2 mb-0"><i class="fa-solid fa-check-circle me-1"></i> Sistema operativo</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card-dashboard h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="text-secondary small text-uppercase fw-bold">Clima</h5>
                    <i id="icono-clima" class="fa-solid fa-spinner text-brand fs-4"></i>
                </div>
                <div class="mt-3">
                    <h3 id="ciudad" class="fs-5 mb-0" style="color: #1a3c1a;">Consultando...</h3>
                    <p id="temperatura" class="text-muted small mb-0"></p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card-dashboard h-100">
                <h5 class="text-secondary small text-uppercase fw-bold">Operaciones</h5>
                <p class="mt-3 mb-0 fw-bold" style="color: #1a3c1a;">Próxima vacunación</p>

                @if (ViewBag.ProximaVacuna != null)
                {
                    <!-- Mostramos el nombre de la vacuna y la fecha -->
                    <p class="mb-0 text-success fw-bold">@ViewBag.ProximaVacuna.nombreVacuna</p>
                    <small class="text-secondary">
                        Fecha: @ViewBag.ProximaVacuna.fechaProximaAplicacion.ToString("dd 'de' MMMM")
                    </small>
                }
                else
                {
                    <small class="text-muted">No hay próximas programadas</small>
                }
            </div>
        </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card-dashboard">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="mb-0 fw-bold" style="color: #1a3c1a;">Gestión de Inventario</h5>
                    <a asp-controller="Animal" asp-action="Create" class="btn btn-campo-dark">
                        <i class="fa-solid fa-plus me-2"></i> Registrar Res
                    </a>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <a asp-controller="Animal" asp-action="Index" class="text-decoration-none">
                            <div class="p-3 border rounded-4 d-flex align-items-center" style="border-color: #d4e0d4 !important; transition: 0.3s;">
                                <div class="icon-box me-3"><i class="fa-solid fa-list-ul"></i></div>
                                <div>
                                    <h6 class="mb-0" style="color: #1a3c1a;">Ver Inventario</h6>
                                    <small class="text-muted">Lista completa de animales</small>
                                </div>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a asp-controller="Home" asp-action="Dashboard" class="text-decoration-none">
                        <div class="p-3 border rounded-4 d-flex align-items-center opacity-50">
                            <div class="icon-box me-3"><i class="fa-solid fa-chart-line"></i></div>
                            <div>
                                <h6 class="mb-0" style="color: #1a3c1a;">Reportes</h6>
                                <small class="text-muted">Ver Dashboard</small>
                            </div>
                        </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>



        <div class="col-lg-4">
            <div class="card-dashboard h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold m-0" style="color:#1a3c1a;">🌿 Mapa del Predio</h5>
                    <a asp-controller="Mapa" asp-action="Index" class="btn btn-sm btn-outline-success">
                        <i class="fa-solid fa-plus"></i>
                    </a>
                </div>

                <div class="row g-2">
                    @if (lista.Any())
                    {
                        @foreach (var potrero in lista.Take(4)) // Mostramos los primeros 4 lotes
                        {
                            <div class="col-6">
                                <div class="position-relative">
                                    @{
                                        var primeraFoto = potrero.RutasFotos?.Split(';').FirstOrDefault();
                                    }

                                    @if (!string.IsNullOrEmpty(primeraFoto))
                                    {
                                        <img src="~/uploads/@primeraFoto" class="img-fluid rounded-3 shadow-sm" style="height:80px;width:100%;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded-3 d-flex align-items-center justify-content-center" style="height:80px;">
                                            <i class="fa-solid fa-image text-muted"></i>
                                        </div>
                                    }

                                    <div class="position-absolute bottom-0 w-100 p-1 text-center"
                                         style="background: rgba(26, 60, 26, 0.7); border-radius: 0 0 6px 6px;">
                                        <small class="text-white fw-bold" style="font-size: 0.7rem;">@potrero.Nombre</small>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12 text-center py-4 border border-dashed rounded-4">
                            <p class="text-muted small">No hay lotes mapeados aún.</p>
                        </div>
                    }
                </div>
            </div>
        </div>


    </div>
</div>

<script>
    async function obtenerClima() {
        try {
            const res = await fetch('https://wttr.in/Santo_Domingo?format=j1');
            const data = await res.json();
            const cond = data.current_condition[0];
            
            document.getElementById('ciudad').innerText = "Santo Domingo";
            document.getElementById('temperatura').innerText = `${cond.temp_C}°C - ${cond.weatherDesc[0].value}`;
            
            const icon = document.getElementById('icono-clima');
            icon.className = `fa-solid ${cond.weatherDesc[0].value.includes("Sun") ? 'fa-sun' : 'fa-cloud'} text-brand fs-4`;
        } catch (e) { console.error("Error clima:", e); }
    }
    obtenerClima();
</script>
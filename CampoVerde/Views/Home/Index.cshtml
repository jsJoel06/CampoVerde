@{
    ViewData["Title"] = "Home Page";
}

<section style="display: flex; flex-direction: row; gap: 20px; ">

    <div class="card w-50  shadow-sm rounded-4 p-3">
        <div class="d-flex align-items-center justify-content-between">
            <h5 class="mb-0">Estado del Rebaño</h5>

            <div class="d-flex gap-3">
                <i class="fa-solid fa-cow" style="color: rgb(151, 252, 173); font-size: 24px;"></i>
                <i class="fa-regular fa-calendar" style="color: rgb(151, 252, 173); font-size: 24px;"></i>
            </div>
        </div>
        <h3 class="mt-2">Saludable</h3>
    </div>

    <div class="card w-50 shadow-sm rounded-4 p-3">
        <div class="d-flex align-items-center justify-content-between">
            <h5>Pronóstico Local</h5>
            <div class="d-flex gap-3">
                <i class="fa-solid fa-cloud" style="color: rgb(116, 192, 252);"></i>
                <i class="fa-regular fa-snowflake" style="color: rgb(116, 192, 252);"></i>

            </div>
        </div>

        <div class="d-flex align-items-center gap-3 mt-2 ">
            <i id="icono-clima" class="fa-solid fa-spinner fa-2x text-success"></i>
            <div>
                <h3 id="ciudad" class="mb-0 fs-5">Cargando...</h3>
                <p id="temperatura" class="text-muted mb-0"></p>
            </div>
        </div>
        <p id="condicion" class="text-secondary small mt-2 mb-0"></p>

        <script>
                    async function obtenerClimaReal() {
                    try {
                    const iconoEl = document.getElementById('icono-clima');
                    const ciudadEl = document.getElementById('ciudad');
                    const tempEl = document.getElementById('temperatura');
                    const condicionEl = document.getElementById('condicion');

                    // Llamada a la API sin necesidad de registro
                    const respuesta = await fetch('https://wttr.in/?format=j1');
                    const data = await respuesta.json();

                    // Extraer datos
                    const temp = data.current_condition[0].temp_C;
                    const desc = data.current_condition[0].weatherDesc[0].value;
                    const ciudad = data.nearest_area[0].areaName[0].value;

                    // Actualizar UI
                    ciudadEl.innerText = ciudad;
                    tempEl.innerText = temp + "°C";
                    condicionEl.innerText = desc;

                    // Cambiar icono dinámicamente según la descripción
                    const descLower = desc.toLowerCase();
                    iconoEl.className = 'fa-solid'; // Limpiar clases anteriores

                    if (descLower.includes("sun") || descLower.includes("clear")) {
                    iconoEl.classList.add('fa-sun');
                    } else if (descLower.includes("cloud")) {
                    iconoEl.classList.add('fa-cloud');
                    } else if (descLower.includes("rain") || descLower.includes("showers")) {
                    iconoEl.classList.add('fa-cloud-showers-heavy');
                    } else if (descLower.includes("thunder")) {
                    iconoEl.classList.add('fa-cloud-bolt');
                    } else {
                    iconoEl.classList.add('fa-cloud-sun');
                    }

                    } catch (error) {
                    console.error("Error al obtener el clima:", error);
                    document.getElementById('ciudad').innerText = "Error de conexión";
                    }
                    }

                    // Ejecutar al cargar la página
                    obtenerClimaReal();
        </script>
    </div>

    <div class="card w-50 shadow-sm rounded-4 p-3">
        <h5>Proxima Tarea</h5>
    </div>

</section>


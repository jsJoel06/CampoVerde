@using CampoVerde.Models
@using System.Text.Json

@{
    ViewData["Title"] = "Dashboard - Campo Verde";

    var rol = Context.Session.GetString("Rol");

    bool esSuperAdmin = rol == EstadoRol.SUPER_ADMINISTRADOR.ToString();
    bool esAdmin = rol == EstadoRol.ADMINISTRADOR.ToString();
    bool esVeterinario = rol == EstadoRol.VETERINARIO.ToString();
    bool esOperario = rol == EstadoRol.OPERARIO.ToString();
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
      rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

    body {
    background: #f5f8f7;
    }

    .dashboard-title {
    font-weight: 800;
    color: #215732;
    }

    .dashboard-subtitle {
    color: #6b7280;
    }

    .kpi-card {
    border: none;
    border-radius: 22px;
    overflow: hidden;
    transition: .3s;
    box-shadow: 0 15px 35px rgba(0,0,0,.08);
    }

    .kpi-card:hover {
    transform: translateY(-6px);
    }

    .kpi-body {
    padding: 28px;
    }

    .kpi-icon {
    width: 65px;
    height: 65px;
    border-radius: 18px;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 28px;
    background: rgba(255,255,255,.20);
    }

    .kpi-number {
    font-size: 32px;
    font-weight: 800;
    }

    .kpi-title {
    opacity: .9;
    }

    .green {
    background: linear-gradient(135deg,#2e7d32,#43a047);
    color: white;
    }

    .blue {
    background: linear-gradient(135deg,#1565c0,#42a5f5);
    color: white;
    }

    .orange {
    background: linear-gradient(135deg,#ef6c00,#ffa726);
    color: white;
    }

    .red {
    background: linear-gradient(135deg,#c62828,#ef5350);
    color: white;
    }

    .quick-card {
    background: white;
    border: none;
    border-radius: 22px;
    box-shadow: 0 10px 25px rgba(0,0,0,.05);
    }

    .quick-btn {
    border-radius: 18px;
    padding: 20px;
    transition: .3s;
    text-decoration: none;
    display: block;
    color: #215732;
    border: 1px solid #e5e7eb;
    background: #fff;
    }

    .quick-btn:hover {
    background: #43a047;
    color: white;
    transform: translateY(-4px);
    }

    .quick-btn i {
    font-size: 35px;
    margin-bottom: 12px;
    }

    .chart-card {
    background: white;
    border: none;
    border-radius: 22px;
    box-shadow: 0 10px 30px rgba(0,0,0,.05);
    }

</style>

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center flex-wrap mb-4">

        <div>

            <h2 class="dashboard-title">

                <i class="fa-solid fa-chart-column text-success"></i>

                Dashboard Campo Verde

            </h2>

            <p class="dashboard-subtitle">

                Bienvenido al panel principal del sistema ganadero.

            </p>

        </div>

        <div>

            <span class="badge bg-success fs-6 p-3">

                <i class="fa-solid fa-user"></i>

                @rol

            </span>

        </div>

    </div>

    <div class="row g-4">

        <div class="col-md-6 col-xl-3">

            <div class="kpi-card green">

                <div class="kpi-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <div class="kpi-title">

                                Animales

                            </div>

                            <div class="kpi-number">

                                @ViewBag.TotalAnimales

                            </div>

                        </div>

                        <div class="kpi-icon">

                            <i class="fa-solid fa-cow"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-md-6 col-xl-3">

            <div class="kpi-card blue">

                <div class="kpi-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <div class="kpi-title">

                                Tareas

                            </div>

                            <div class="kpi-number">

                                @ViewBag.TareasPendientes

                            </div>

                        </div>

                        <div class="kpi-icon">

                            <i class="fa-solid fa-list-check"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-md-6 col-xl-3">

            <div class="kpi-card orange">

                <div class="kpi-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <div class="kpi-title">

                                Ingresos

                            </div>

                            <div class="kpi-number">

                                RD$ @ViewBag.IngresosMes.ToString("N0")

                            </div>

                        </div>

                        <div class="kpi-icon">

                            <i class="fa-solid fa-money-bill-wave"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-md-6 col-xl-3">

            <div class="kpi-card red">

                <div class="kpi-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <div class="kpi-title">

                                Vacunas

                            </div>

                            <div class="kpi-number">

                                @ViewBag.VacunasVencidas

                            </div>

                        </div>

                        <div class="kpi-icon">

                            <i class="fa-solid fa-syringe"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="quick-card mt-5 p-4">

        <h4 class="mb-4">

            <i class="fa-solid fa-bolt text-warning"></i>

            Accesos rápidos

        </h4>

        <div class="row g-3">

            <!-- ACCESOS RAPIDOS -->

            <div class="col-md-3">

                <a asp-controller="Animal"
                   asp-action="Index"
                   class="quick-btn text-center">

                    <i class="fa-solid fa-cow"></i>

                    <h6>
                        Animales
                    </h6>

                </a>

            </div>


            <div class="col-md-3">

                <a asp-controller="Produccion"
                   asp-action="Index"
                   class="quick-btn text-center">

                    <i class="fa-solid fa-droplet"></i>

                    <h6>
                        Producción
                    </h6>

                </a>

            </div>


            <div class="col-md-3">

                <a asp-controller="Vacuna"
                   asp-action="Index"
                   class="quick-btn text-center">

                    <i class="fa-solid fa-syringe"></i>

                    <h6>
                        Vacunas
                    </h6>

                </a>

            </div>


            <div class="col-md-3">

                <a asp-controller="Alimentos"
                   asp-action="Index"
                   class="quick-btn text-center">

                    <i class="fa-solid fa-seedling"></i>

                    <h6>
                        Alimentos
                    </h6>

                </a>

            </div>


        </div>

    </div>


    <!-- PRODUCCION Y ESTADO -->

    <div class="row g-4 mt-4">


        <div class="col-lg-8">


            <div class="chart-card p-4">


                <h5 class="fw-bold text-success mb-4">

                    <i class="fa-solid fa-chart-line"></i>

                    Producción de Leche

                </h5>


                <canvas id="produccionChart"></canvas>


            </div>


        </div>



        <div class="col-lg-4">


            <div class="chart-card p-4">


                <h5 class="fw-bold text-success mb-4">

                    <i class="fa-solid fa-heart-pulse"></i>

                    Estado del Ganado

                </h5>


                <canvas id="estadoChart"></canvas>


            </div>


        </div>


    </div>



    <!-- RESUMEN PRODUCCION -->


    <div class="row g-4 mt-4">


        <div class="col-md-4">


            <div class="chart-card p-4 text-center">


                <i class="fa-solid fa-sun text-warning fs-1"></i>


                <h6 class="mt-3 text-muted">

                    Producción Hoy

                </h6>


                <h2 class="fw-bold text-success">

                    @ViewBag.ProduccionHoy L

                </h2>


            </div>


        </div>




        <div class="col-md-4">


            <div class="chart-card p-4 text-center">


                <i class="fa-solid fa-calendar-week text-primary fs-1"></i>


                <h6 class="mt-3 text-muted">

                    Producción Semana

                </h6>


                <h2 class="fw-bold text-success">

                    @ViewBag.ProduccionSemana L

                </h2>


            </div>


        </div>





        <div class="col-md-4">


            <div class="chart-card p-4 text-center">


                <i class="fa-solid fa-calendar-days text-danger fs-1"></i>


                <h6 class="mt-3 text-muted">

                    Producción Mes

                </h6>


                <h2 class="fw-bold text-success">

                    @ViewBag.ProduccionMes L

                </h2>


            </div>


        </div>


    </div>
    <!-- GRAFICOS FINANCIEROS -->

    <div class="row g-4 mt-4">


        <div class="col-lg-7">

            <div class="chart-card p-4">

                <h5 class="fw-bold text-success mb-4">

                    <i class="fa-solid fa-chart-column"></i>

                    Ingresos vs Gastos

                </h5>


                <canvas id="finanzasChart"></canvas>


            </div>


        </div>



        <div class="col-lg-5">


            <div class="chart-card p-4">


                <h5 class="fw-bold text-success mb-4">

                    <i class="fa-solid fa-triangle-exclamation"></i>

                    Alertas del Sistema

                </h5>



                <div class="list-group">


                    <div class="list-group-item d-flex justify-content-between">

                        <span>
                            💉 Vacunas pendientes
                        </span>

                        <span class="badge bg-danger">

                            @ViewBag.VacunasVencidas

                        </span>

                    </div>



                    <div class="list-group-item d-flex justify-content-between">

                        <span>
                            🌱 Stock bajo alimento
                        </span>

                        <span class="badge bg-warning text-dark">

                            @ViewBag.StockBajo

                        </span>

                    </div>



                    <div class="list-group-item d-flex justify-content-between">

                        <span>
                            🍼 Próximos partos
                        </span>

                        <span class="badge bg-success">

                            @ViewBag.ProximosPartos

                        </span>

                    </div>


                    <div class="list-group-item d-flex justify-content-between">

                        <span>
                            📋 Tareas pendientes
                        </span>

                        <span class="badge bg-primary">

                            @ViewBag.TareasPendientes

                        </span>

                    </div>


                </div>


            </div>


        </div>


    </div>




    <!-- ESTADO GENERAL GANADO -->


    <div class="row g-4 mt-4">


        <div class="col-md-4">


            <div class="chart-card p-4 text-center">


                <i class="fa-solid fa-cow text-success fs-1"></i>


                <h6 class="mt-3 text-muted">

                    Animales Activos

                </h6>


                <h2 class="fw-bold text-success">

                    @ViewBag.AnimalesActivos

                </h2>


            </div>


        </div>




        <div class="col-md-4">


            <div class="chart-card p-4 text-center">


                <i class="fa-solid fa-heart-crack text-danger fs-1"></i>


                <h6 class="mt-3 text-muted">

                    Animales Enfermos

                </h6>


                <h2 class="fw-bold text-danger">

                    @ViewBag.AnimalesEnfermos

                </h2>


            </div>


        </div>




        <div class="col-md-4">


            <div class="chart-card p-4 text-center">


                <i class="fa-solid fa-eye text-warning fs-1"></i>


                <h6 class="mt-3 text-muted">

                    En Observación

                </h6>


                <h2 class="fw-bold text-warning">

                    @ViewBag.AnimalesObservacion

                </h2>


            </div>


        </div>


    </div>



    <!-- JAVASCRIPT CHARTS -->
    <script>
        const labels = @Html.Raw(JsonSerializer.Serialize((object)ViewBag.Labels));
        const datos = @Html.Raw(JsonSerializer.Serialize((object)ViewBag.Litros));

        new Chart(document.getElementById('produccionChart'), {
        type: 'line',
        data: {
        labels: labels,
        datasets: [{
        label: 'Litros de leche',
        data: datos,
        borderWidth: 3,
        tension: 0.4,
        fill: true,
        backgroundColor: 'rgba(67,160,71,.15)',
        borderColor: '#2e7d32'
        }]
        },
        options: {
        responsive: true
        }
        });
    </script>



        

        <script>
        // Estado animales
        new Chart(

        document.getElementById('estadoChart'),

        {

        type:'doughnut',


        data:{


        labels:[

        'Activos',
        'Enfermos',
        'Observación'

        ],


        datasets:[{

        data:[

        @ViewBag.AnimalesActivos,

        @ViewBag.AnimalesEnfermos,

        @ViewBag.AnimalesObservacion

        ],


        backgroundColor:[

        '#2e7d32',
        '#e53935',
        '#ffb300'

        ]


        }]


        },


        options:{

        cutout:'70%',

        responsive:true


        }


        });






        // Finanzas


        new Chart(

        document.getElementById('finanzasChart'),

        {


        type:'bar',


        data:{


        labels:[

        'Ingresos',
        'Gastos'

        ],



        datasets:[{


        label:'RD$',


        data:[

        @ViewBag.IngresosMes,

        @ViewBag.GastosMes

        ],



        backgroundColor:[

        '#43a047',
        '#e53935'

        ],


        borderRadius:12


        }]


        },



        options:{


        responsive:true,


        scales:{


        y:{


        beginAtZero:true


        }


        }


        }



        });


    </script>
    <!-- ACTIVIDAD RECIENTE -->

    <div class="row g-4 mt-4">


        <!-- ULTIMOS ANIMALES -->

        <div class="col-lg-6">

            <div class="chart-card p-4">

                <h5 class="fw-bold text-success mb-4">

                    <i class="fa-solid fa-cow"></i>

                    Últimos Animales Registrados

                </h5>


                <div class="list-group">


                    @if (ViewBag.UltimosAnimales != null)
                    {

                        foreach (var animal in ViewBag.UltimosAnimales)
                        {

                            <div class="list-group-item d-flex justify-content-between align-items-center">


                                <div>

                                    <strong>
                                        @animal.nombre
                                    </strong>

                                    <br />

                                    <small class="text-muted">

                                        Código:
                                        @animal.codigo

                                    </small>

                                </div>


                                <span class="badge bg-success rounded-pill">

                                    @animal.Estado

                                </span>


                            </div>

                        }

                    }
                    else
                    {

                        <div class="text-muted text-center">

                            No hay registros recientes.

                        </div>

                    }


                </div>


            </div>


        </div>






        <!-- PROXIMOS PARTOS -->


        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-sm p-4 h-100">

                <div class="d-flex align-items-center justify-content-between">


                    <div>

                        <span class="text-muted fw-semibold">
                            Ganancia del mes
                        </span>


                        <h3 class="fw-bold text-success mt-2 mb-1">

                            RD$
                            @(ViewBag.GananciaMes != null
                                ? ViewBag.GananciaMes.ToString("N2")
                                : "0.00")

                        </h3>


                        <small class="text-success">

                            <i class="fa-solid fa-arrow-trend-up"></i>
                            Ingresos - Gastos

                        </small>


                    </div>



                    <div class="rounded-circle bg-success bg-opacity-10 p-3">

                        <i class="fa-solid fa-sack-dollar text-success fs-2"></i>

                    </div>


                </div>


            </div>

        </div>


    </div>





    <!-- MENU SEGUN ROL -->


    <div class="row mt-5">


        <div class="col-12">


            <div class="chart-card p-4">


                <h5 class="fw-bold text-success mb-4">


                    <i class="fa-solid fa-shield-halved"></i>


                    Módulos disponibles


                </h5>



                <div class="row g-3">



                    @if (esSuperAdmin || esAdmin)
                    {


                        <div class="col-md-3">

                            <a asp-controller="Usuario"
                               asp-action="Index"
                               class="quick-btn text-center">


                                <i class="fa-solid fa-users"></i>


                                <h6>

                                    Usuarios

                                </h6>


                            </a>


                        </div>


                    }

                    @if (esSuperAdmin)
                    {
                        <div class="col-md-3">

                            <a asp-controller="Cliente"
                               asp-action="Index"
                               class="quick-btn text-center">

                                <i class="fa-solid fa-building"></i>

                                <h6>
                                    Clientes
                                </h6>

                            </a>

                        </div>
                    }

                    @if (esSuperAdmin || esAdmin || esOperario)
                    {
                        <div class="col-md-3">
                            <a asp-controller="TransaccionAnimal"
                            asp-action="Index"
                            class="quick-btn text-center">
                                <i class="fa-solid fa-seedling"></i>
                                <h6>
                                    Transaccion Animal
                                </h6>
                            </a>
                        </div>
                    }




                    @if (esSuperAdmin || esAdmin || esVeterinario)
                    {


                        <div class="col-md-3">


                            <a asp-controller="Vacuna"
                               asp-action="Index"
                               class="quick-btn text-center">


                                <i class="fa-solid fa-syringe"></i>


                                <h6>

                                    Vacunación

                                </h6>


                            </a>


                        </div>



                    }



                    @if (esSuperAdmin || esAdmin || esOperario)
                    {


                        <div class="col-md-3">


                            <a asp-controller="Tarea"
                               asp-action="Index"
                               class="quick-btn text-center">


                                <i class="fa-solid fa-list-check"></i>


                                <h6>

                                    Tareas

                                </h6>


                            </a>


                        </div>


                    }



                </div>


            </div>


        </div>


    </div>




</div>


<!-- FOOTER DASHBOARD -->


<div class="text-center mt-5 mb-3 text-muted">


    <i class="fa-solid fa-leaf text-success"></i>


    Campo Verde Sistema Ganadero


    <br>


    <small>

        Control inteligente de producción y administración

    </small>


</div>
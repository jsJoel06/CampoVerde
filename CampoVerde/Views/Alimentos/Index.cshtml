@model IEnumerable<CampoVerde.Models.AlimentoBovino>
@using CampoVerde.Models

@{
    ViewData["Title"] = "Inventario de Alimentos";

    var rol = Context.Session.GetString("Rol");

    bool puedeEditar =
        rol == EstadoRol.SUPER_ADMINISTRADOR.ToString() ||
        rol == EstadoRol.ADMINISTRADOR.ToString() ||
        rol == EstadoRol.OPERARIO.ToString();

    var total = Model.Count();
    var stockBajo = Model.Count(x => x.CantidadDisponible <= x.NivelAlerta);
    var stockOk = total - stockBajo;
}

<style>
    body {
        background: #eef7ee;
    }

    .page-title {
        color: #2e7d32;
        font-weight: 700;
    }

    .card-inventario {
        border: none;
        border-radius: 22px;
        overflow: hidden;
    }

    .card-header-verde {
        background: linear-gradient(135deg,#2e7d32,#43a047);
        color: white;
        padding: 20px;
    }

    .btn-verde {
        background: #2e7d32;
        color: white;
        border: none;
        border-radius: 10px;
    }

        .btn-verde:hover {
            background: #256628;
            color: white;
        }

    .table thead {
        background: #dcedc8;
    }

        .table thead th {
            color: #2e7d32;
            border: none;
            font-weight: 600;
        }

    .table tbody tr:hover {
        background: #f7fcf7;
    }

    .badge-categoria {
        background: #43a047;
        color: white;
        padding: 8px 14px;
        border-radius: 20px;
    }

    .estado-ok {
        color: #2e7d32;
        font-weight: 600;
    }

    .estado-alerta {
        color: #d32f2f;
        font-weight: 600;
    }

    .card-kpi {
        border: none;
        border-radius: 20px;
        box-shadow: 0 5px 20px rgba(0,0,0,.08);
        transition: .3s;
    }

        .card-kpi:hover {
            transform: translateY(-5px);
        }

    .icono {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 28px;
    }
</style>

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="page-title">
                🌿 Inventario de Alimentos
            </h2>

            <p class="text-muted">
                Administración del inventario de alimentos para el ganado.
            </p>

        </div>

        <div>

            <a asp-action="Historial" class="btn btn-outline-secondary me-2">
                <i class="bi bi-clock-history"></i>
                Historial
            </a>

            @if (puedeEditar)
            {
                <a asp-action="AddForm" class="btn btn-verde">
                    <i class="bi bi-plus-circle-fill"></i>
                    Nuevo Alimento
                </a>
            }

        </div>

    </div>

    <!-- Indicadores -->

    <div class="row mb-4">

        <div class="col-md-4">

            <div class="card card-kpi p-3">

                <div class="d-flex align-items-center">

                    <div class="icono bg-success text-white">
                        <i class="bi bi-basket-fill"></i>
                    </div>

                    <div class="ms-3">

                        <small class="text-muted">
                            Total de alimentos
                        </small>

                        <h3>@total</h3>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card card-kpi p-3">

                <div class="d-flex align-items-center">

                    <div class="icono bg-warning text-dark">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>

                    <div class="ms-3">

                        <small class="text-muted">
                            Stock bajo
                        </small>

                        <h3>@stockBajo</h3>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card card-kpi p-3">

                <div class="d-flex align-items-center">

                    <div class="icono bg-primary text-white">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>

                    <div class="ms-3">

                        <small class="text-muted">
                            Stock óptimo
                        </small>

                        <h3>@stockOk</h3>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="card card-inventario shadow">

        <div class="card-header-verde">

            <h4 class="mb-0">
                <i class="bi bi-box-seam"></i>
                Lista de Alimentos
            </h4>

        </div>

        <div class="card-body p-0">

            <table class="table table-hover align-middle mb-0">

                <thead>

                    <tr>

                        <th class="ps-4">Nombre</th>

                        <th>Categoría</th>

                        <th>Disponible</th>

                        <th>Estado</th>

                        <th class="text-center">Acciones</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td class="ps-4">
                                <strong>@item.Nombre</strong>
                            </td>

                            <td>
                                <span class="badge-categoria">
                                    @item.Categoria
                                </span>
                            </td>

                            <td>
                                <strong>@item.CantidadDisponible</strong>
                                @item.Unidad
                            </td>

                            <td>

                                @if (item.CantidadDisponible <= item.NivelAlerta)
                                {
                                    <span class="estado-alerta">
                                        ⚠ Stock Bajo
                                    </span>
                                }
                                else
                                {
                                    <span class="estado-ok">
                                        ✔ Stock Óptimo
                                    </span>
                                }

                            </td>

                            <td class="text-center">

                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-outline-info btn-sm"
                                   title="Ver">
                                    <i class="bi bi-eye-fill"></i>
                                </a>

                                @if (puedeEditar)
                                {
                                    <a asp-action="AddForm"
                                       asp-route-id="@item.Id"
                                       class="btn btn-outline-success btn-sm"
                                       title="Editar">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="btn btn-outline-danger btn-sm"
                                       title="Eliminar">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                }

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>
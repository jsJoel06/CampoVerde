@model CampoVerde.Models.Tarea

@{
    ViewData["Title"] = "Detalles de la Tarea";
}

<style>
    body {
        background: #eef6ee;
    }

    .card-campo {
        border: none;
        border-radius: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .header-campo {
        background: linear-gradient(135deg,#2e7d32,#4caf50);
        color: white;
        padding: 25px;
    }

    .info-card {
        background: white;
        border-radius: 18px;
        padding: 20px;
        box-shadow: 0 3px 12px rgba(0,0,0,.05);
        height: 100%;
        transition: .3s;
    }

        .info-card:hover {
            transform: translateY(-4px);
        }

    .titulo {
        font-size: .85rem;
        color: #6c757d;
        margin-bottom: 5px;
    }

    .valor {
        font-size: 1.2rem;
        font-weight: 600;
        color: #1b4332;
    }

    .btn-campo {
        background: #2e7d32;
        color: white;
        border-radius: 50px;
        padding: 10px 25px;
    }

        .btn-campo:hover {
            background: #1b5e20;
            color: white;
        }

    .badge-prioridad {
        font-size: 15px;
        padding: 10px 18px;
    }
</style>

<div class="container py-5">

    <div class="card card-campo">

        <div class="header-campo d-flex justify-content-between align-items-center">

            <div>

                <h2 class="fw-bold mb-1">
                    <i class="bi bi-list-check"></i>
                    Detalles de la Tarea
                </h2>

                <small>Campo Verde • Gestión Ganadera</small>

            </div>

            <span class="badge bg-light text-success fs-6">
                ID #@Model.IdTarea
            </span>

        </div>

        <div class="card-body p-4">

            <div class="row g-4">

                <div class="col-md-6">
                    <div class="info-card">
                        <div class="titulo">
                            <i class="bi bi-card-text"></i>
                            Descripción
                        </div>

                        <div class="valor">
                            @Model.Descripcion
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="info-card">
                        <div class="titulo">
                            <i class="bi bi-cow"></i>
                            Animal
                        </div>

                        <div class="valor">
                            @(Model.Animal?.nombre ?? "Sin animal")
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="info-card">
                        <div class="titulo">
                            <i class="bi bi-calendar-event"></i>
                            Fecha de vencimiento
                        </div>

                        <div class="valor">
                            @Model.FechaVencimiento.ToString("dd/MM/yyyy")
                        </div>
                    </div>
                </div>

                <div class="col-md-6">

                    <div class="info-card">

                        <div class="titulo">
                            <i class="bi bi-flag-fill"></i>
                            Prioridad
                        </div>

                        @if (Model.Prioridad.ToString() == "Urgente")
                        {
                            <span class="badge bg-dark badge-prioridad">@Model.Prioridad</span>
                        }
                        else if (Model.Prioridad.ToString() == "Alta")
                        {
                            <span class="badge bg-danger badge-prioridad">@Model.Prioridad</span>
                        }
                        else if (Model.Prioridad.ToString() == "Media")
                        {
                            <span class="badge bg-warning text-dark badge-prioridad">@Model.Prioridad</span>
                        }
                        else
                        {
                            <span class="badge bg-success badge-prioridad">@Model.Prioridad</span>
                        }

                    </div>

                </div>

                <div class="col-md-6">
                    <div class="info-card">

                        <div class="titulo">
                            <i class="bi bi-check-circle"></i>
                            Estado
                        </div>

                        @if (Model.Completada)
                        {
                            <span class="badge bg-success fs-6">
                                ✔ Completada
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark fs-6">
                                Pendiente
                            </span>
                        }

                    </div>
                </div>

                <div class="col-md-6">
                    <div class="info-card">

                        <div class="titulo">
                            <i class="bi bi-diagram-3"></i>
                            Estado del Registro
                        </div>

                        <div class="valor">
                            @Model.estado
                        </div>

                    </div>
                </div>

                <div class="col-md-6">
                    <div class="info-card">

                        <div class="titulo">
                            <i class="bi bi-person-fill"></i>
                            Encargado
                        </div>

                        <div class="valor">
                            @Model.Encargado
                        </div>

                    </div>
                </div>

                <div class="col-12">
                    <div class="info-card">

                        <div class="titulo">
                            <i class="bi bi-journal-text"></i>
                            Observaciones
                        </div>

                        <div class="valor">
                            @(string.IsNullOrWhiteSpace(Model.Notas)
                                ? "No existen observaciones."
                                : Model.Notas)
                        </div>

                    </div>
                </div>

            </div>

        </div>

    </div>

    <div class="mt-4 d-flex justify-content-end gap-3">

        <a asp-action="Edit"
           asp-route-id="@Model.IdTarea"
           class="btn btn-campo">

            <i class="bi bi-pencil-square"></i>
            Editar

        </a>

        <a asp-action="Index"
           class="btn btn-outline-secondary rounded-pill">

            <i class="bi bi-arrow-left"></i>
            Volver

        </a>

    </div>

</div>
@model CampoVerde.Models.Tarea

@{
    ViewData["Title"] = "Completar Tarea";
}

<style>
    body {
        background: #eef5ec;
        font-family: 'Segoe UI', sans-serif;
    }

    .card-completar {
        max-width: 650px;
        margin: 60px auto;
        background: #fff;
        border-radius: 25px;
        border: 1px solid #d9e6d6;
        box-shadow: 0 15px 40px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .header-card {
        background: linear-gradient(135deg,#2e7d32,#43a047);
        color: white;
        padding: 30px;
        text-align: center;
    }

    .icono {
        width: 90px;
        height: 90px;
        margin: auto;
        border-radius: 50%;
        background: rgba(255,255,255,.15);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
    }

    .contenido {
        padding: 35px;
    }

    dt {
        color: #5d6d5d;
        font-weight: 600;
    }

    dd {
        font-weight: 700;
        color: #1d3c1d;
        margin-bottom: 20px;
    }

    .btn-confirmar {
        background: #2e7d32;
        color: white;
        border-radius: 50px;
        padding: 12px 35px;
        border: none;
    }

    .btn-confirmar:hover {
        background: #1b5e20;
        color: white;
    }

    .btn-cancelar {
        border-radius: 50px;
        padding: 12px 35px;
    }
</style>

<div class="card card-completar">

    <div class="header-card">

        <div class="icono">
            <i class="bi bi-check2-circle"></i>
        </div>

        <h2 class="mt-3">
            Completar Tarea
        </h2>

        <p class="mb-0">
            ¿Deseas marcar esta tarea como completada?
        </p>

    </div>

    <div class="contenido">

        <dl class="row">

            <dt class="col-sm-4">
                Animal
            </dt>

            <dd class="col-sm-8">
                @(Model.Animal?.nombre ?? "Sin asignar")
            </dd>

            <dt class="col-sm-4">
                Descripción
            </dt>

            <dd class="col-sm-8">
                @Model.Descripcion
            </dd>

            <dt class="col-sm-4">
                Prioridad
            </dt>

            <dd class="col-sm-8">
                <span class="badge bg-warning text-dark">
                    @Model.Prioridad
                </span>
            </dd>

            <dt class="col-sm-4">
                Fecha límite
            </dt>

            <dd class="col-sm-8">
                @Model.FechaVencimiento.ToString("dd/MM/yyyy")
            </dd>

            <dt class="col-sm-4">
                Estado
            </dt>

            <dd class="col-sm-8">

                @if (Model.Completada)
                {
                    <span class="badge bg-success">
                        Completada
                    </span>
                }
                else
                {
                    <span class="badge bg-danger">
                        Pendiente
                    </span>
                }

            </dd>

        </dl>

        <form asp-action="Completar">

            <input type="hidden" asp-for="IdTarea" />

            @Html.AntiForgeryToken()

            <div class="d-flex justify-content-between">

                <a asp-action="Index"
                   class="btn btn-outline-secondary btn-cancelar">

                    Cancelar

                </a>

                <button type="submit"
                        class="btn btn-confirmar">

                    <i class="bi bi-check-circle-fill"></i>

                    Confirmar

                </button>

            </div>

        </form>

    </div>

</div>
@using CampoVerde.Models
@model IEnumerable<CampoVerde.Models.Animal>

@{
    ViewData["Title"] = "Control Vacuno";

    var rolActual = Context.Session.GetString("Rol");

    bool puedeEditar =
        rolActual == "SUPER_ADMINISTRADOR" ||
        rolActual == "ADMINISTRADOR";
}


@functions {
    string GetEstadoBadge(EstadoAnimal estado) => estado switch
    {
        EstadoAnimal.ACTIVO => "bg-success text-white",
        EstadoAnimal.ENFERMO => "bg-danger text-white",
        EstadoAnimal.OBSERVACION => "bg-warning text-dark",
        _ => "bg-secondary text-white"
    };
}


<style>

    body {
        background-color: #eaf2e9;
    }


    .table-container {
        background: #fdfdf5;
        border: 1px solid #d4e0d4;
        border-radius: 25px;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(74,124,74,0.05);
        overflow-x: auto;
    }


    .table thead th {
        color: #3d663d;
        font-size: .75rem;
        text-transform: uppercase;
        letter-spacing: .1em;
        border-bottom: 2px solid #d4e0d4;
        white-space: nowrap;
    }


    .table tbody tr {
        transition: .3s;
        border-bottom: 1px solid #eef2ed;
    }


        .table tbody tr:hover {
            background: #f5f9f5;
        }


    .btn-campo {
        background-color: #1a3c1a;
        color: white;
        border-radius: 50px;
        padding: 10px 25px;
        font-weight: 600;
    }


        .btn-campo:hover {
            background-color: #3d663d;
            color: white;
        }


    .btn-action {
        width: 38px;
        height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
    }


    @@media(max-width:768px) {

        .hide-mobile {
            display: none !important;
        }


        .table-container {
            padding: 1rem;
        }
    }

</style>



<div class="container py-5">


    <div class="header-section d-flex justify-content-between align-items-center mb-4">


        <div>

            <h2 class="fw-bold" style="color:#1a3c1a">

                Control de Ganado Vacuno

            </h2>


            <p style="color:#3d663d">

                Administración de inventario, lotes y pesaje

            </p>

        </div>



        @if (puedeEditar)
        {

            <a asp-action="Create" class="btn btn-campo">

                <i class="fa-solid fa-plus me-2"></i>

                <span class="hide-mobile">
                    Registrar Res
                </span>

            </a>

        }


    </div>




    @if (!Model?.Any() ?? true)
    {

        <div class="text-center py-5" style="color:#3d663d">


            <i class="fa-solid fa-cow fs-1 mb-3"></i>


            <p>
                No hay reses registradas en el sistema.
            </p>


        </div>

    }

    else
    {

        <div class="row mb-4">

            <div class="col-md-5">

                <div class="input-group">

                    <span class="input-group-text bg-white">
                        <i class="fa-solid fa-magnifying-glass text-success"></i>
                    </span>

                    <input type="text"
                           id="buscarAnimal"
                           class="form-control"
                           placeholder="Buscar por código, nombre, raza o lote...">

                </div>

            </div>

        </div>


        <div class="table-container shadow-sm">


            <table class="table align-middle" id="tablaAnimales">


                <thead>


                    <tr>


                        <th>
                            Imagen
                        </th>


                        <th>
                            Código
                        </th>


                        <th>
                            Nombre
                        </th>


                        <th class="hide-mobile">
                            Raza
                        </th>


                        <th class="hide-mobile">
                            Nacimiento
                        </th>


                        <th>
                            Lote
                        </th>


                        <th>
                            Peso
                        </th>


                        <th>
                            Estado
                        </th>


                        <th class="text-end pe-3">
                            Acciones
                        </th>


                    </tr>


                </thead>



                <tbody>


                    @foreach (var item in Model)
                    {


                        <tr>


                            <td>


                                @if (!string.IsNullOrEmpty(item.imagen))
                                {

                                    <img src="@item.imagen"
                                         alt="@item.nombre"
                                         style="width:45px;height:45px;object-fit:cover;border-radius:10px;" />

                                }
                                else
                                {

                                    <i class="fa-solid fa-cow text-muted fs-4"></i>

                                }


                            </td>



                            <td>

                                <strong style="color:#1a3c1a">
                                    @item.codigo
                                </strong>

                            </td>



                            <td style="color:#2d4d2d">

                                @(item.nombre ?? "N/A")

                            </td>



                            <td class="hide-mobile">

                                @item.raza

                            </td>



                            <td class="hide-mobile">

                                @(item.fechaNacimiento?.ToString("dd/MM/yyyy") ?? "N/A")

                            </td>



                            <td>


                                <span class="badge rounded-pill"
                                      style="background:#eaf2e9;color:#1a3c1a;border:1px solid #d4e0d4">

                                    @item.lote

                                </span>


                            </td>



                            <td>


                                <strong style="color:#1a3c1a">

                                    @item.pesoActual.ToString("F1") kg

                                </strong>
                            </td>
                            <td>


                                <span class="badge rounded-pill @GetEstadoBadge(item.Estado)">

                                    @item.Estado

                                </span>
                            </td>
                            <td class="text-end pe-3">


                                <div class="d-flex justify-content-end gap-2">


                                    <!-- TODOS LOS ROLES PUEDEN VER -->

                                    <a asp-action="Details"
                                       asp-route-id="@item.IdAnimal"
                                       class="btn btn-outline-success btn-action"
                                       title="Ver">

                                        <i class="fa-solid fa-eye"></i>

                                    </a>


                                    @if (puedeEditar)
                                    {


                                        <a asp-action="Edit"
                                           asp-route-id="@item.IdAnimal"
                                           class="btn btn-outline-primary btn-action"
                                           title="Editar">

                                            <i class="fa-solid fa-pen"></i>

                                        </a>



                                        <a asp-action="Delete"
                                           asp-route-id="@item.IdAnimal"
                                           class="btn btn-outline-danger btn-action"
                                           title="Eliminar">

                                            <i class="fa-solid fa-trash"></i>

                                        </a>


                                    }


                                </div>


                            </td>



                        </tr>


                    }


                </tbody>


            </table>


        </div>


    }

    <script>
            document.getElementById("buscarAnimal").addEventListener("keyup", function () {

                let filtro = this.value.toLowerCase();

                let filas = document.querySelectorAll("#tablaAnimales tbody tr");

                filas.forEach(function (fila) {

                    let texto = fila.innerText.toLowerCase();

                    if (texto.includes(filtro)) {
                        fila.style.display = "";
                    } else {
                        fila.style.display = "none";
                    }

                });

            });
    </script>


</div>
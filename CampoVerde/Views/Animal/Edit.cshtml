@model CampoVerde.Models.Animal

@{
    ViewData["Title"] = "Editar Animal - Campo Verde";
}

<style>
    body {
        background-color: #eaf2e9;
        font-family: 'Segoe UI', sans-serif;
    }

    .card-ganaderia {
        background-color: #fdfdf5;
        border-radius: 30px;
        box-shadow: 0 10px 30px rgba(74, 124, 74, 0.1);
        padding: 45px;
        border: 1px solid #d4e0d4;
    }

    h2 {
        font-family: 'Georgia', serif;
        color: #1a3c1a;
        font-weight: 700;
        margin-bottom: 35px;
    }

    .form-label {
        color: #3d663d;
        font-weight: 600;
    }

    .form-control, .form-select {
        background-color: #f5f9f5 !important;
        border: 1px solid #c8d9c8;
        border-radius: 15px;
        padding: 12px 18px;
        color: #2d3a2d;
    }

        .form-control:focus {
            border-color: #4a7c4a;
            box-shadow: 0 0 0 0.2rem rgba(74, 124, 74, 0.25);
        }

    .btn-guardar {
        background: linear-gradient(135deg, #4a7c4a, #346334);
        color: white;
        border-radius: 50px;
        padding: 12px 45px;
        font-weight: bold;
        border: none;
        transition: all 0.4s ease;
    }

        .btn-guardar:hover {
            background: #2d4d2d;
            transform: translateY(-3px);
            box-shadow: 0 6px 15px rgba(61, 102, 61, 0.3);
            color: white;
        }

    .btn-cancelar {
        background-color: #d1e0d1;
        color: #2d4d2d;
        border-radius: 50px;
        padding: 12px 35px;
        border: none;
        text-decoration: none;
    }
</style>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-9 col-lg-8">
            <div class="card card-ganaderia">
                <h2>Editar información: @Model.codigo</h2>

                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="IdAnimal" />
                    <input type="hidden" asp-for="imagen" />

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label asp-for="nombre" class="form-label">Nombre / Identificador</label>
                            <input asp-for="nombre" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-4">
                            <label asp-for="codigo" class="form-label">Código (Arete)</label>
                            <input asp-for="codigo" class="form-control" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label asp-for="raza" class="form-label">Raza</label>
                            <input asp-for="raza" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-4">
                            <label asp-for="Estado" class="form-label">Estado Actual</label>
                            <select asp-for="Estado" class="form-select">
                                @foreach (var e in Enum.GetValues(typeof(EstadoAnimal)))
                                {
                                    <option value="@e">@e</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label asp-for="lote" class="form-label">Lote / Potrero</label>
                            <input asp-for="lote" class="form-control" placeholder="Ej. Lote 01" />
                        </div>
                        <div class="col-md-6 mb-4">
                            <label asp-for="pesoActual" class="form-label">Peso Actual (kg)</label>
                            <input asp-for="pesoActual" type="number" step="0.1" class="form-control" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            <label asp-for="fechaNacimiento" class="form-label">Fecha de Nacimiento</label>
                            <input asp-for="fechaNacimiento" type="date" class="form-control" />
                        </div>
                        <div class="col-md-12 mb-4">
                            <label class="form-label">Cambiar Fotografía</label>
                            <input type="file" name="imagenArchivo" class="form-control" accept="image/*" />
                            @if (!string.IsNullOrEmpty(Model.imagen))
                            {
                                <div class="mt-3">
                                    <small class="text-muted">Imagen actual:</small><br />
                                    <img src="@Model.imagen" style="width: 100px; border-radius: 15px; border: 2px solid #d4e0d4;" alt="Imagen del animal" />
                                </div>
                            }
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <a asp-action="Index" class="btn btn-cancelar">Cancelar</a>
                        <button type="submit" class="btn btn-guardar">Guardar cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
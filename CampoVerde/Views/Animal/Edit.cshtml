@model CampoVerde.Models.Animal

@{
    ViewData["Title"] = "Editar Animal - Campo Verde";
}

<style>

    body {
        background-color: #eaf2e9;
        font-family: 'Segoe UI', sans-serif;
    }


    .card-ganaderia {
        background-color: #fdfdf5;
        border-radius: 30px;
        box-shadow: 0 10px 30px rgba(74,124,74,.1);
        padding: 45px;
        border: 1px solid #d4e0d4;
    }


    h2 {
        font-family: Georgia,serif;
        color: #1a3c1a;
        font-weight: 700;
        margin-bottom: 35px;
    }


    .form-label {
        color: #3d663d;
        font-weight: 600;
    }


    .form-control,
    .form-select {
        background: #f5f9f5 !important;
        border: 1px solid #c8d9c8;
        border-radius: 15px;
        padding: 12px 18px;
    }


        .form-control:focus,
        .form-select:focus {
            border-color: #4a7c4a;
            box-shadow: 0 0 0 .2rem rgba(74,124,74,.25);
        }


    .btn-guardar {
        background: linear-gradient(135deg,#4a7c4a,#346334);
        color: white;
        border-radius: 50px;
        padding: 12px 45px;
        font-weight: bold;
        border: none;
    }


        .btn-guardar:hover {
            background: #2d4d2d;
            color: white;
        }


    .btn-cancelar {
        background: #d1e0d1;
        color: #2d4d2d;
        border-radius: 50px;
        padding: 12px 35px;
        text-decoration: none;
    }

</style>



<div class="container mt-5 mb-5">

    <div class="row justify-content-center">

        <div class="col-md-9 col-lg-8">


            <div class="card card-ganaderia">


                <h2>
                    Editar información: @Model.codigo
                </h2>



                <form asp-action="Edit"
                      method="post"
                      enctype="multipart/form-data">


                    <input type="hidden" asp-for="IdAnimal" />

                    <input type="hidden" asp-for="imagen" />

                    <input type="hidden" asp-for="FechaEmbarazo" />

                    <div class="row">


                        <div class="col-md-6 mb-4">

                            <label class="form-label">
                                Nombre / Identificador
                            </label>

                            <input asp-for="nombre"
                                   class="form-control" />

                        </div>



                        <div class="col-md-6 mb-4">

                            <label class="form-label">
                                Código (Arete)
                            </label>

                            <input asp-for="codigo"
                                   class="form-control" />

                        </div>


                    </div>





                    <div class="row">


                        <div class="col-md-6 mb-4">


                            <label class="form-label">
                                Raza
                            </label>


                            <input asp-for="raza"
                                   class="form-control" />


                        </div>





                        <div class="col-md-6 mb-4">


                            <label class="form-label">
                                Estado Actual
                            </label>


                            <select asp-for="Estado"
                                    id="estadoAnimal"
                                    class="form-select">


                                @foreach (var estado in Enum.GetValues(typeof(EstadoAnimal)))
                                {

                                    <option value="@estado">
                                        @estado
                                    </option>

                                }


                            </select>



                        </div>


                    </div>







                    <!-- FECHA EMBARAZO -->


                    <div class="mb-4"
                         id="divFechaEmbarazo"
                         style="display:none;">


                        <label class="form-label">

                            Fecha de detección del embarazo

                        </label>


                        <input asp-for="FechaEmbarazo"
                               type="date"
                               class="form-control" />


                        <small class="text-muted">

                            Fecha en que se confirmó el embarazo.

                        </small>


                    </div>








                    <div class="row">


                        <div class="col-md-6 mb-4">


                            <label class="form-label">
                                Lote / Potrero
                            </label>


                            <input asp-for="lote"
                                   class="form-control"
                                   placeholder="Ej. Lote 01" />


                        </div>




                        <div class="col-md-6 mb-4">


                            <label class="form-label">
                                Peso Actual (kg)
                            </label>


                            <input asp-for="pesoActual"
                                   type="number"
                                   step="0.1"
                                   class="form-control" />


                        </div>



                    </div>








                    <div class="mb-4">


                        <label class="form-label">
                            Fecha de Nacimiento
                        </label>


                        <input asp-for="fechaNacimiento"
                               type="date"
                               class="form-control" />


                    </div>







                    <div class="mb-4">


                        <label class="form-label">
                            Cambiar Fotografía
                        </label>


                        <input type="file"
                               name="imagenArchivo"
                               class="form-control"
                               accept="image/*" />



                        @if (!string.IsNullOrEmpty(Model.imagen))
                        {

                            <div class="mt-3">


                                <small class="text-muted">
                                    Imagen actual:
                                </small>


                                <br />


                                <img src="@Model.imagen"
                                     style="width:120px;
                                border-radius:15px;
                                border:2px solid #d4e0d4;" />


                            </div>


                        }


                    </div>






                    <div class="d-flex justify-content-between mt-4">


                        <a asp-action="Index"
                           class="btn btn-cancelar">

                            Cancelar

                        </a>



                        <button type="submit"
                                class="btn btn-guardar">

                            Guardar cambios

                        </button>


                    </div>





                </form>



            </div>


        </div>

    </div>

</div>






@section Scripts {


    <script>


        function mostrarFechaEmbarazo()
        {

            let estado =
            document.getElementById("estadoAnimal").value;


            let campo =
            document.getElementById("divFechaEmbarazo");



            if(estado === "EMBARAZADA")
            {

                campo.style.display="block";

            }
            else
            {

                campo.style.display="none";

            }


        }



        document.addEventListener("DOMContentLoaded",function(){

            mostrarFechaEmbarazo();


            document
            .getElementById("estadoAnimal")
            .addEventListener("change",
            mostrarFechaEmbarazo);


        });


    </script>


}
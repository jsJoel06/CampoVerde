@model CampoVerde.Models.Animal

@{
    ViewData["Title"] = "Eliminar Registro";
}

<style>
    .delete-container {
        max-width: 600px;
        margin: auto;
    }

    .card-delete {
        background-color: #ffffff;
        border-radius: 30px;
        border-left: 8px solid #dc3545;
        box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        padding: 40px;
    }

    .header-delete {
        color: #8b1c1c;
        font-size: 1.8rem;
    }

    .info-label {
        color: #6c757d;
        font-size: 0.9rem;
        text-transform: uppercase;
        font-weight: 600;
    }

    .info-value {
        color: #2d3a2d;
        font-size: 1.1rem;
        font-weight: 700;
    }

    .btn-danger-custom {
        background-color: #dc3545;
        color: white;
        border-radius: 50px;
        padding: 12px 30px;
        transition: all 0.3s;
    }

        .btn-danger-custom:hover {
            background-color: #b02a37;
            transform: translateY(-3px);
            color: white;
        }
</style>

<div class="container py-5 delete-container">
    <div class="text-center mb-5">
        <h2 class="header-delete fw-bold mb-3">
            <i class="fa-solid fa-triangle-exclamation me-2"></i> Confirmar Eliminación
        </h2>
        <p class="text-secondary">¿Está seguro de que desea eliminar este registro? <br> Esta acción es definitiva y no se puede deshacer.</p>
    </div>

    <div class="card card-delete border-0">
        <h5 class="mb-4 fw-bold" style="color: #1a3c1a;">Datos del ejemplar seleccionado</h5>

        <div class="row">
            <div class="col-6 mb-3">
                <p class="info-label mb-0">Código (Arete)</p>
                <p class="info-value">@Model.codigo</p>
            </div>
            <div class="col-6 mb-3">
                <p class="info-label mb-0">Nombre</p>
                <p class="info-value">@Model.nombre</p>
            </div>
            <div class="col-6 mb-3">
                <p class="info-label mb-0">Raza</p>
                <p class="info-value">@Model.raza</p>
            </div>
            <div class="col-6 mb-3">
                <p class="info-label mb-0">Lote / Potrero</p>
                <p class="info-value">@Model.lote</p>
            </div>
            <div class="col-12 mb-3">
                <p class="info-label mb-0">Estado</p>
                <span class="badge rounded-pill bg-light border text-dark px-3 py-2 mt-1">@Model.Estado</span>
            </div>
        </div>

        <hr class="my-4" style="border-color: #eee;">

        <form asp-action="Delete">
            <input type="hidden" asp-for="IdAnimal" />
            <div class="d-flex flex-column gap-3">
                <button type="submit" class="btn btn-danger-custom">
                    <i class="fa-solid fa-trash me-2"></i> Eliminar permanentemente
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill border-0">Cancelar y volver</a>
            </div>
        </form>
    </div>
</div>
@model IEnumerable<CampoVerde.Models.Usuario>

@{
    ViewData["Title"] = "Gestión de Usuarios";

    var totalUsuarios = Model.Count();
    var activos = Model.Count(x => x.estadoActivo);
    var inactivos = Model.Count(x => !x.estadoActivo);
}


<style>

    body {
        background: #eaf2e9;
        font-family: 'Segoe UI',sans-serif;
    }

    .card-usuario {
        background: #fdfdf5;
        border-radius: 30px;
        border: 1px solid #d4e0d4;
        box-shadow: 0 10px 30px rgba(74,124,74,.10);
        padding: 35px;
    }

    .titulo {
        color: #1a3c1a;
        font-family: Georgia,serif;
        font-weight: 700;
    }

    .resumen {
        border-radius: 20px;
        padding: 25px;
        color: white;
        box-shadow: 0 8px 20px rgba(0,0,0,.12);
    }

    .total {
        background: linear-gradient(135deg,#2d6a4f,#40916c);
    }

    .activos {
        background: linear-gradient(135deg,#198754,#20c997);
    }

    .inactivos {
        background: linear-gradient(135deg,#dc3545,#ff6b6b);
    }

    .numero {
        font-size: 2rem;
        font-weight: 800;
    }

    .btn-nuevo {
        background: linear-gradient(135deg,#4a7c4a,#346334);
        color: white;
        border-radius: 50px;
        padding: 12px 30px;
        font-weight: bold;
        text-decoration: none;
    }

        .btn-nuevo:hover {
            color: white;
            transform: translateY(-2px);
        }

    .table {
        border-collapse: separate;
        border-spacing: 0 12px;
    }

        .table thead th {
            background: #d4e0d4;
            color: #1a3c1a;
            padding: 15px;
            border: none;
        }

        .table tbody tr {
            background: white;
            box-shadow: 0 5px 15px rgba(0,0,0,.05);
        }

        .table tbody td {
            padding: 15px;
            vertical-align: middle;
        }


    .badge-rol {
        padding: 8px 15px;
        border-radius: 20px;
        font-weight: 600;
    }

    .super {
        background: #212529;
        color: white;
    }

    .admin {
        background: #0d6efd;
        color: white;
    }

    .veterinario {
        background: #198754;
        color: white;
    }

    .operario {
        background: #ffc107;
        color: #212529;
    }

    .activo {
        background: #d1e7dd;
        color: #0f5132;
    }

    .inactivo {
        background: #f8d7da;
        color: #842029;
    }

    .session {
        background: #e2e3e5;
        color: #41464b;
        border-radius: 15px;
        padding: 7px 12px;
        font-size: .85rem;
    }

    .action-btn {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

</style>



<div class="container py-5">


    <div class="row g-4 mb-4">


        <div class="col-md-4">
            <div class="resumen total">

                <h6>
                    <i class="fa-solid fa-users"></i>
                    Usuarios Totales
                </h6>

                <div class="numero">
                    @totalUsuarios
                </div>

            </div>
        </div>



        <div class="col-md-4">
            <div class="resumen activos">

                <h6>
                    <i class="fa-solid fa-user-check"></i>
                    Usuarios Activos
                </h6>

                <div class="numero">
                    @activos
                </div>

            </div>
        </div>



        <div class="col-md-4">
            <div class="resumen inactivos">

                <h6>
                    <i class="fa-solid fa-user-slash"></i>
                    Usuarios Inactivos
                </h6>

                <div class="numero">
                    @inactivos
                </div>

            </div>
        </div>


    </div>




    <div class="card-usuario">


        <div class="d-flex justify-content-between align-items-center mb-4">

            <h2 class="titulo">
                <i class="fa-solid fa-users-gear"></i>
                Gestión de Usuarios
            </h2>


            <a asp-action="Create" class="btn-nuevo">

                <i class="fa-solid fa-plus"></i>
                Nuevo Usuario

            </a>


        </div>





        <div class="table-responsive">

            <table class="table">


                <thead>

                    <tr>

                        <th>Nombre</th>

                        <th>Email</th>

                        <th>Cliente</th>

                        <th>Rol</th>

                        <th>Estado</th>

                        <th>Última sesión</th>

                        <th class="text-center">
                            Acciones
                        </th>


                    </tr>

                </thead>



                <tbody>


                    @foreach (var item in Model)
                    {

                        <tr>


                            <td class="fw-bold">
                                @item.nombre
                            </td>



                            <td>
                                @item.email
                            </td>



                            <td>

                                @if (item.Cliente != null)
                                {
                                    <span>
                                        <i class="fa-solid fa-building me-1"></i>
                                        @item.Cliente.NombreEmpresa
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">
                                        Sistema General
                                    </span>
                                }

                            </td>



                            <td>

                                @if (item.Rol.ToString() == "SUPER_ADMINISTRADOR")
                                {
                                    <span class="badge-rol super">
                                        Super Admin
                                    </span>
                                }
                                else if (item.Rol.ToString() == "ADMINISTRADOR")
                                {
                                    <span class="badge-rol admin">
                                        Administrador
                                    </span>
                                }
                                else if (item.Rol.ToString() == "VETERINARIO")
                                {
                                    <span class="badge-rol veterinario">
                                        Veterinario
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-rol operario">
                                        Operario
                                    </span>
                                }

                            </td>



                            <td>

                                @if (item.estadoActivo)
                                {
                                    <span class="badge-rol activo">
                                        Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-rol inactivo">
                                        Inactivo
                                    </span>
                                }

                            </td>




                            <td>

                                @if (item.UltimoAcceso == DateTime.MinValue)
                                {
                                    <span class="text-muted">
                                        Nunca
                                    </span>
                                }
                                else
                                {
                                    <span class="session">

                                        <i class="fa-solid fa-clock me-1"></i>

                                        @item.UltimoAcceso.ToLocalTime().ToString("dd/MM/yyyy HH:mm")

                                    </span>
                                }

                            </td>



                            <td class="text-center">


                                <a asp-action="Details"
                                   asp-route-id="@item.IdUsuario"
                                   class="btn btn-outline-info action-btn">

                                    <i class="fa-solid fa-eye"></i>

                                </a>


                                <a asp-action="Edit"
                                   asp-route-id="@item.IdUsuario"
                                   class="btn btn-outline-warning action-btn">

                                    <i class="fa-solid fa-pen"></i>

                                </a>


                                <a asp-action="Delete"
                                   asp-route-id="@item.IdUsuario"
                                   class="btn btn-outline-danger action-btn">

                                    <i class="fa-solid fa-trash"></i>

                                </a>


                            </td>


                        </tr>

                    }


                </tbody>


            </table>

        </div>


    </div>


</div>
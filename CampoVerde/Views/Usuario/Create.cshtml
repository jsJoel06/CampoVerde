@model CampoVerde.Models.Usuario

@{
    ViewData["Title"] = "Crear Usuario";

    var rolActual = Context.Session.GetString("Rol");
}


<style>

    body {
        background: #eaf2e9;
        font-family: 'Segoe UI',sans-serif;
    }


    .usuario-container {
        max-width: 1000px;
        margin: auto;
    }


    .card-usuario {
        background: #fdfdf5;
        border-radius: 30px;
        border: 1px solid #d4e0d4;
        box-shadow: 0 15px 35px rgba(74,124,74,.12);
        overflow: hidden;
    }



    .card-header-usuario {
        background: linear-gradient( 135deg, #1a3c1a, #4a7c4a );
        color: white;
        padding: 25px;
    }



        .card-header-usuario h3 {
            font-family: Georgia,serif;
            font-weight: 700;
        }




    .form-control,
    .form-select {
        border-radius: 15px;
        padding: 12px;
        border: 1px solid #c8d9c8;
    }



        .form-control:focus,
        .form-select:focus {
            border-color: #4a7c4a;
            box-shadow: 0 0 0 .2rem rgba(74,124,74,.25);
        }




    .form-label {
        font-weight: 600;
        color: #1a3c1a;
    }




    .icon-title {
        width: 50px;
        height: 50px;
        background: #d4e0d4;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1a3c1a;
        font-size: 20px;
    }




    .btn-guardar {
        background: linear-gradient( 135deg, #4a7c4a, #346334 );
        color: white;
        border-radius: 50px;
        padding: 12px 35px;
        font-weight: bold;
        border: none;
        transition: .3s;
    }



        .btn-guardar:hover {
            transform: translateY(-3px);
            color: white;
        }



    .btn-cancelar {
        border-radius: 50px;
        padding: 12px 30px;
    }




    .seccion-title {
        color: #1a3c1a;
        font-weight: 700;
        margin-bottom: 20px;
        border-bottom: 2px solid #d4e0d4;
        padding-bottom: 10px;
    }

</style>




<div class="container py-5 usuario-container">


    <div class="card-usuario">



        <div class="card-header-usuario">


            <div class="d-flex align-items-center">


                <div class="icon-title me-3">

                    <i class="fa-solid fa-user-plus"></i>

                </div>


                <div>


                    <h3 class="mb-0">

                        Crear Usuario

                    </h3>


                    <small>

                        Gestión de accesos Campo Verde

                    </small>


                </div>


            </div>


        </div>





        <div class="card-body p-5">


            <form asp-action="Create"
                  method="post">



                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3"></div>



                <h5 class="seccion-title">

                    <i class="fa-solid fa-user"></i>

                    Información Personal

                </h5>



                <div class="row">



                    <div class="col-md-6 mb-3">


                        <label asp-for="nombre"
                               class="form-label">

                            Nombre completo

                        </label>


                        <input asp-for="nombre"
                               class="form-control"
                               placeholder="Ej: Juan Pérez" />


                        <span asp-validation-for="nombre"
                              class="text-danger"></span>


                    </div>





                    <div class="col-md-6 mb-3">


                        <label asp-for="email"
                               class="form-label">

                            Correo electrónico

                        </label>


                        <input asp-for="email"
                               class="form-control"
                               placeholder="correo@email.com" />


                        <span asp-validation-for="email"
                              class="text-danger"></span>


                    </div>





                    <div class="col-md-6 mb-3">


                        <label asp-for="telefono"
                               class="form-label">

                            Teléfono

                        </label>


                        <input asp-for="telefono"
                               class="form-control"
                               placeholder="809-000-0000" />


                    </div>





                    <div class="col-md-6 mb-3">


                        <label asp-for="password"
                               class="form-label">

                            Contraseña

                        </label>


                        <input asp-for="password"
                               type="password"
                               class="form-control"
                               placeholder="********" />


                        <span asp-validation-for="password"
                              class="text-danger"></span>


                    </div>



                </div>






                <h5 class="seccion-title mt-4">

                    <i class="fa-solid fa-shield-halved"></i>

                    Permisos y Estado

                </h5>





                <div class="row">



                    <div class="col-md-6 mb-3">


                        <label asp-for="Rol"
                               class="form-label">

                            Rol del usuario

                        </label>



                        <select asp-for="Rol"
                                class="form-select">



                            @if (rolActual == "SUPER_ADMINISTRADOR")
                            {


                                <option value="SUPER_ADMINISTRADOR">
                                    Super Administrador
                                </option>


                                <option value="ADMINISTRADOR">
                                    Administrador
                                </option>


                                <option value="VETERINARIO">
                                    Veterinario
                                </option>


                                <option value="OPERARIO">
                                    Operario
                                </option>


                            }



                            else if (rolActual == "ADMINISTRADOR")
                            {


                                <option value="VETERINARIO">
                                    Veterinario
                                </option>


                                <option value="OPERARIO">
                                    Operario
                                </option>


                            }



                        </select>


                    </div>





                    <div class="col-md-6 mb-3">


                        <label asp-for="estadoActivo"
                               class="form-label">

                            Estado

                        </label>


                        <select asp-for="estadoActivo"
                                class="form-select">


                            <option value="true">

                                Activo

                            </option>


                            <option value="false">

                                Inactivo

                            </option>


                        </select>


                    </div>



                </div>





                <div class="mt-5 d-flex gap-3">


                    <button type="submit"
                            class="btn-guardar">


                        <i class="fa-solid fa-save"></i>

                        Guardar Usuario


                    </button>



                    <a asp-action="Perfil"
                       class="btn btn-secondary btn-cancelar">


                        <i class="fa-solid fa-arrow-left"></i>

                        Cancelar


                    </a>



                </div>




            </form>


        </div>



    </div>


</div>




@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
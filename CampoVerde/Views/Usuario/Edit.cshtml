@model CampoVerde.Models.Usuario

@{
    ViewData["Title"] = "Editar Usuario";
    var rolActual = Context.Session.GetString("Rol");
}

<style>

    body {
        background: #eaf2e9;
        font-family: 'Segoe UI',sans-serif;
    }

    .card-usuario {
        background: #fdfdf5;
        border-radius: 30px;
        padding: 35px;
        border: 1px solid #d4e0d4;
        box-shadow: 0 10px 30px rgba(74,124,74,.12);
    }

    .titulo-icon {
        width: 55px;
        height: 55px;
        border-radius: 20px;
        background: #d4e0d4;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1a3c1a;
        font-size: 22px;
    }

    h2 {
        color: #1a3c1a;
        font-family: Georgia,serif;
        font-weight: 700;
    }

    .form-control,
    .form-select {
        border-radius: 15px;
        padding: 12px;
        border: 1px solid #cdddc9;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: #4a7c4a;
            box-shadow: 0 0 0 .2rem rgba(74,124,74,.25);
        }

    .form-label {
        color: #1a3c1a;
    }

    .seccion-title {
        color: #1a3c1a;
        font-weight: 700;
        border-bottom: 2px solid #d4e0d4;
        padding-bottom: 10px;
        margin: 20px 0;
    }

    .cliente-box {
        background: #f1f8f1;
        padding: 15px;
        border-radius: 20px;
    }

    .btn-guardar {
        background: #1a3c1a;
        color: white;
        border-radius: 50px;
        padding: 12px 35px;
        font-weight: bold;
        border: none;
    }

        .btn-guardar:hover {
            background: #3d663d;
            color: white;
        }

    .btn-cancelar {
        border-radius: 50px;
        padding: 12px 30px;
    }

</style>


<div class="container py-5">

    <div class="card-usuario">

        <div class="d-flex align-items-center mb-4">

            <div class="titulo-icon me-3">
                <i class="fa-solid fa-user-pen"></i>
            </div>

            <div>
                <h2 class="mb-0">Editar Usuario</h2>
                <p class="text-muted mb-0">
                    Actualización de información del usuario
                </p>
            </div>

        </div>



        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="IdUsuario" />


            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>



            <h5 class="seccion-title">
                <i class="fa-solid fa-user me-2"></i>
                Información Personal
            </h5>



            <div class="row">


                <div class="col-md-6 mb-3">
                    <label asp-for="nombre" class="form-label fw-bold">
                        Nombre completo
                    </label>

                    <input asp-for="nombre" class="form-control" />

                    <span asp-validation-for="nombre"
                          class="text-danger">
                    </span>
                </div>



                <div class="col-md-6 mb-3">
                    <label asp-for="email" class="form-label fw-bold">
                        Correo electrónico
                    </label>

                    <input asp-for="email" class="form-control" />

                    <span asp-validation-for="email"
                          class="text-danger">
                    </span>
                </div>



                <div class="col-md-6 mb-3">
                    <label asp-for="telefono" class="form-label fw-bold">
                        Teléfono
                    </label>

                    <input asp-for="telefono" class="form-control" />
                </div>


                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">
                        Estado
                    </label>

                    <select asp-for="estadoActivo" class="form-select">

                        <option value="true">
                            Activo
                        </option>

                        <option value="false">
                            Inactivo
                        </option>

                    </select>

                </div>


            </div>




            @if (rolActual == "SUPER_ADMINISTRADOR")
            {

                <h5 class="seccion-title">
                    <i class="fa-solid fa-building me-2"></i>
                    Cliente asignado
                </h5>


                <div class="cliente-box mb-3">


                    <label asp-for="ClienteId"
                           class="form-label fw-bold">
                        Finca o empresa
                    </label>


                    <select asp-for="ClienteId"
                            asp-items="ViewBag.Clientes"
                            class="form-select">

                        <option value="">
                            Seleccionar cliente
                        </option>

                    </select>


                    <span asp-validation-for="ClienteId"
                          class="text-danger">
                    </span>


                </div>

            }






            <h5 class="seccion-title">
                <i class="fa-solid fa-shield-halved me-2"></i>
                Permisos
            </h5>



            <div class="row">

                <div class="col-md-6 mb-3">

                    <label asp-for="Rol"
                           class="form-label fw-bold">
                        Rol del usuario
                    </label>


                    <select asp-for="Rol"
                            class="form-select">


                        @if (rolActual == "SUPER_ADMINISTRADOR")
                        {

                            <option value="ADMINISTRADOR">
                                Administrador
                            </option>

                            <option value="VETERINARIO">
                                Veterinario
                            </option>

                            <option value="OPERARIO">
                                Operario
                            </option>

                        }

                        else if (rolActual == "ADMINISTRADOR")
                        {

                            <option value="VETERINARIO">
                                Veterinario
                            </option>

                            <option value="OPERARIO">
                                Operario
                            </option>

                        }


                    </select>

                </div>

            </div>




            <div class="mt-4">


                <button type="submit"
                        class="btn btn-guardar me-2">

                    <i class="fa-solid fa-save me-2"></i>
                    Guardar Cambios

                </button>



                <a asp-action="Index"
                   class="btn btn-outline-secondary btn-cancelar">

                    <i class="fa-solid fa-arrow-left me-2"></i>
                    Volver

                </a>


            </div>


        </form>


    </div>

</div>


@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
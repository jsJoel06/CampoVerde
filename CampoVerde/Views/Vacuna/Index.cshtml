@model IEnumerable<CampoVerde.Models.Vacuna>
@using CampoVerde.Models

@{
    ViewData["Title"] = "Control de Vacunas";

    var rol = Context.Session.GetString("Rol");

    bool puedeCrear =
        rol == EstadoRol.SUPER_ADMINISTRADOR.ToString() ||
        rol == EstadoRol.ADMINISTRADOR.ToString() ||
        rol == EstadoRol.VETERINARIO.ToString();

    bool puedeEditar = puedeCrear;

    bool puedeEliminar =
        rol == EstadoRol.SUPER_ADMINISTRADOR.ToString() ||
        rol == EstadoRol.ADMINISTRADOR.ToString();
}

<style>
    body {
        background-color: #eaf2e9;
    }

    .card-ganaderia {
        background-color: #fdfdf5;
        border-radius: 30px;
        box-shadow: 0 10px 30px rgba(74,124,74,.1);
        padding: 20px;
        border: 1px solid #d4e0d4;
    }

    h2 {
        font-family: Georgia, serif;
        color: #1a3c1a;
        font-weight: 700;
    }

    .table thead {
        background-color: #2d5a27 !important;
        color: white;
    }

    .badge-vencido {
        background: #a94442;
        color: white;
    }

    .badge-ok {
        background: #4a7c44;
        color: white;
    }

    .btn-campo-verde {
        background: linear-gradient(135deg,#5c9a5c,#3d663d);
        color: white;
        border-radius: 50px;
        padding: 10px 20px;
        font-weight: bold;
    }

    @@media(max-width:768px) {

        .hide-mobile {
            display: none !important;
        }

        .card-ganaderia {
            padding: 15px;
            border-radius: 20px;
        }

        .btn-campo-verde span {
            display: none;
        }
    }
</style>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>
            <i class="bi bi-shield-check"></i>
            Vacunas
        </h2>

        @if (puedeCrear)
        {
            <a asp-action="Create" class="btn btn-campo-verde">
                <i class="bi bi-plus-lg"></i>
                <span class="hide-mobile">Registrar Nueva</span>
            </a>
        }

    </div>

    <div class="row mb-4">

        <div class="col-md-5">

            <div class="input-group">

                <span class="input-group-text bg-white">
                    <i class="fa-solid fa-magnifying-glass text-success"></i>
                </span>

                <input type="text"
                       id="buscarVacuna"
                       class="form-control"
                       placeholder="Buscar por animal, vacuna u observación...">

            </div>

        </div>

    </div>

    <div class="card-ganaderia">

        <div class="table-responsive">
            

            <table class="table table-hover align-middle mb-0" id="tablaVacunas">

                <thead>
                    <tr>
                        <th class="ps-4">Nombre</th>
                        <th>Vacuna</th>
                        <th class="hide-mobile">Frecuencia</th>
                        <th>Próxima dosis</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        var hoy = DateTime.Today;

                        var vencida = item.fechaProximaAplicacion != DateTime.MinValue &&
                                      item.fechaProximaAplicacion < hoy;

                        <tr class="@(vencida ? "table-danger" : "")">

                            <td class="ps-4">
                                <span class="badge rounded-pill bg-success">
                                    @(item.Animal?.nombre ?? "Sin nombre")
                                </span>
                            </td>

                            <td>
                                <div class="fw-bold">
                                    @item.nombreVacuna
                                </div>

                                <small class="text-muted hide-mobile">
                                    @item.observaciones
                                </small>
                            </td>

                            <td class="hide-mobile">
                                @item.frecuenciaMeses meses
                            </td>

                            <td>

                                <span class="badge @(vencida ? "badge-vencido" : "badge-ok") rounded-pill px-3 py-2">

                                    @(item.fechaProximaAplicacion == DateTime.MinValue
                                        ? "N/A"
                                        : item.fechaProximaAplicacion.ToString("dd/MM/yyyy"))

                                </span>

                            </td>

                            <td class="text-center">

                                <div class="btn-group btn-group-sm">

                                    <!-- TODOS -->
                                    <a asp-action="Details"
                                       asp-route-id="@item.IdVacuna"
                                       class="btn btn-outline-success"
                                       title="Detalles">

                                        <i class="fa-solid fa-eye"></i>

                                    </a>

                                    @if (puedeEditar)
                                    {
                                        <a asp-action="Edit"
                                           asp-route-id="@item.IdVacuna"
                                           class="btn btn-outline-primary"
                                           title="Editar">

                                            <i class="fa-solid fa-pen"></i>

                                        </a>
                                    }

                                    @if (puedeEliminar)
                                    {
                                        <a asp-action="Delete"
                                           asp-route-id="@item.IdVacuna"
                                           class="btn btn-outline-danger"
                                           title="Eliminar">

                                            <i class="fa-solid fa-trash"></i>

                                        </a>
                                    }

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>
    <script>

            document.getElementById("buscarVacuna").addEventListener("keyup", function () {

                let filtro = this.value.toLowerCase();

                let filas = document.querySelectorAll("#tablaVacunas tbody tr");

                filas.forEach(function (fila) {

                    let texto = fila.innerText.toLowerCase();

                    if (texto.includes(filtro)) {
                        fila.style.display = "";
                    } else {
                        fila.style.display = "none";
                    }

                });

            });

    </script>
</div>
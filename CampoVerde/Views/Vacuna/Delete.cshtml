@model CampoVerde.Models.Vacuna

@{
    ViewData["Title"] = "Eliminar Registro";
}

<style>
    .delete-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(220, 53, 69, 0.15);
    }

    .icon-box {
        font-size: 3rem;
        color: #dc3545;
        margin-bottom: 10px;
    }

    .detail-item {
        background-color: #fff5f5;
        padding: 10px;
        border-radius: 10px;
        margin-bottom: 10px;
        border-left: 4px solid #dc3545;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card delete-card p-4">
                <div class="card-body text-center">
                    <div class="icon-box">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                    <h3 class="text-dark fw-bold">¿Deseas eliminar este registro?</h3>
                    <p class="text-muted">Esta acción es permanente y no podrá ser recuperada.</p>

                    <div class="text-start mt-4">
                        <div class="detail-item">
                            <strong>Vacuna:</strong> @Model.nombreVacuna
                        </div>
                        <div class="detail-item">
                            <strong>ID Animal:</strong> @Model.IdAnimal
                        </div>
                        <div class="detail-item">
                            <strong>Nombre Animal:</strong> @(Model.Animal?.nombre ?? "N/A")
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white border-0 text-center pb-3">
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="IdVacuna" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill">
                                <i class="bi bi-trash-fill"></i> Sí, eliminar permanentemente
                            </button>
                            <a asp-action="Index" class="btn btn-link text-secondary text-decoration-none">
                                Cancelar y volver
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
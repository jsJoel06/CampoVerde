@model CampoVerde.Models.Vacuna

@{
    ViewData["Title"] = "Detalles de Vacunación";
}

<style>
    .card-custom {
        border: none;
        border-radius: 25px;
        background: #ffffff;
        box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .header-custom {
        background: linear-gradient(135deg, #2d5a27 0%, #4a7c4a 100%);
        padding: 30px;
        color: white;
    }

    .detail-label {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #6c757d;
        font-weight: 700;
    }

    .detail-value {
        font-size: 1.1rem;
        color: #212529;
        margin-bottom: 20px;
    }

    .badge-frecuencia {
        background-color: #eaf2e9;
        color: #2d5a27;
        padding: 5px 15px;
        border-radius: 20px;
        font-weight: 600;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card card-custom">
                <!-- Encabezado con estilo -->
                <div class="header-custom text-center">
                    <i class="bi bi-shield-check display-4"></i>
                    <h2 class="mt-2">Ficha de Vacunación</h2>
                    <p class="mb-0 opacity-75">Detalles del registro clínico</p>
                </div>

                <div class="card-body p-4">
                    <div class="row mt-3">
                        <div class="col-sm-6">
                            <p class="detail-label mb-1">Nombre de la Vacuna</p>
                            <p class="detail-value fw-bold">@Model.nombreVacuna</p>
                        </div>
                        <div class="col-sm-6">
                            <p class="detail-label mb-1">Nombre del Animal</p>
                            <p class="detail-value">@(Model.Animal?.nombre ?? "Sin nombre")</p>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-sm-6">
                            <p class="detail-label mb-1">Frecuencia</p>
                            <p class="detail-value">
                                <span class="badge-frecuencia">@Model.frecuenciaMeses meses</span>
                            </p>
                        </div>
                        <div class="col-sm-6">
                            <p class="detail-label mb-1">Fecha de Aplicación</p>
                            <p class="detail-value">@Model.fechaAplicacion.ToString("dd/MM/yyyy")</p>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <p class="detail-label mb-1">Observaciones</p>
                            <div class="p-3 bg-light rounded-3 border-start border-4 border-success">
                                @(string.IsNullOrEmpty(Model.observaciones) ? "Sin observaciones adicionales." : Model.observaciones)
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-light p-4 d-flex justify-content-between align-items-center border-0">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">
                        <i class="bi bi-arrow-left"></i> Volver
                    </a>
                    <div>
                        <a asp-action="Edit" asp-route-id="@Model?.IdVacuna" class="btn btn-success px-4 rounded-pill">
                            <i class="bi bi-pencil-square"></i> Editar
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model?.IdVacuna" class="btn btn-danger px-4 rounded-pill ms-2">
                            <i class="bi bi-trash"></i> Eliminar
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
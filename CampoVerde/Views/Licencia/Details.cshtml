@model CampoVerde.Models.Licencia

@{
    ViewData["Title"] = "Detalles de Licencia";
}


<style>

    body {
        background: #eaf2e9;
        font-family: 'Segoe UI',sans-serif;
    }


    .card-ganaderia {
        border-radius: 18px;
        background: white;
        box-shadow: 0 8px 20px rgba(0,0,0,.08);
    }


    .header-verde {
        background: linear-gradient(135deg,#2e7d32,#66bb6a);
        color: white;
        border-radius: 18px 18px 0 0;
    }


    .icon-box {
        width: 55px;
        height: 55px;
        background: rgba(255,255,255,.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 25px;
    }


    .info-card {
        background: #f8faf8;
        border-radius: 15px;
        padding: 15px;
        border-left: 5px solid #2e7d32;
    }


    .label-title {
        font-size: 14px;
        color: #666;
        font-weight: bold;
    }


    .value-text {
        font-size: 18px;
        font-weight: 600;
    }


    .btn {
        border-radius: 12px;
    }

</style>





<div class="container py-5">


    <div class="card card-ganaderia border-0">



        <!-- HEADER -->

        <div class="card-header header-verde p-4">


            <div class="d-flex align-items-center">


                <div class="icon-box">

                    <i class="bi bi-card-checklist"></i>

                </div>



                <div class="ms-3">


                    <h3 class="mb-1 fw-bold">

                        Detalles de Licencia

                    </h3>


                    <p class="mb-0">

                        Información del plan contratado

                    </p>


                </div>


            </div>


        </div>







        <div class="card-body p-4">



            <div class="row">



                <!-- DATOS CLIENTE -->


                <div class="col-md-6 mb-4">


                    <div class="info-card mb-3">


                        <div class="label-title">

                            <i class="bi bi-person-circle text-success"></i>

                            Cliente

                        </div>


                        <div class="value-text">

                            @Model.Cliente.Nombre

                        </div>


                    </div>





                    <div class="info-card mb-3">


                        <div class="label-title">

                            <i class="bi bi-building text-success"></i>

                            Empresa

                        </div>


                        <div class="value-text">

                            @Model.Cliente.NombreEmpresa

                        </div>


                    </div>





                    <div class="info-card">


                        <div class="label-title">

                            <i class="bi bi-star text-success"></i>

                            Plan contratado

                        </div>


                        <div class="value-text">

                            @Model.Plan

                        </div>


                    </div>


                </div>









                <!-- DATOS LICENCIA -->


                <div class="col-md-6 mb-4">


                    <div class="info-card mb-3">


                        <div class="label-title">

                            <i class="bi bi-calendar text-success"></i>

                            Fecha inicio

                        </div>


                        <div class="value-text">

                            @Model.FechaInicio.ToString("dd/MM/yyyy")

                        </div>


                    </div>





                    <div class="info-card mb-3">


                        <div class="label-title">

                            <i class="bi bi-calendar-check text-success"></i>

                            Fecha vencimiento

                        </div>


                        <div class="value-text">

                            @Model.FechaVencimiento.ToString("dd/MM/yyyy")

                        </div>


                    </div>





                    <div class="info-card">


                        <div class="label-title">

                            <i class="bi bi-shield-check text-success"></i>

                            Estado

                        </div>



                        @if (Model.Estado == "ACTIVA")
                        {

                            <span class="badge bg-success fs-6 mt-2">

                                <i class="bi bi-check-circle"></i>

                                ACTIVA

                            </span>

                        }
                        else
                        {

                            <span class="badge bg-danger fs-6 mt-2">

                                <i class="bi bi-x-circle"></i>

                                VENCIDA

                            </span>

                        }


                    </div>


                </div>


            </div>






            <hr>





            <div class="mt-3">


                <a asp-action="Edit"
                   asp-route-id="@Model.IdLicencia"
                   class="btn btn-success px-4">


                    <i class="bi bi-pencil"></i>

                    Editar


                </a>




                <a asp-action="Index"
                   class="btn btn-outline-secondary ms-2 px-4">


                    <i class="bi bi-arrow-left"></i>

                    Volver


                </a>



            </div>



        </div>


    </div>


</div>
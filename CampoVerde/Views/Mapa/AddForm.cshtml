@model CampoVerde.Models.Potrero

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="mb-4 text-center">
                <h2 class="fw-black text-uppercase" style="letter-spacing: 1px; color: #1a3c1a;">
                    @(Model.Id == 0 ? "Nuevo Potrero" : "Configurar Lote")
                </h2>
                <div class="bg-success mx-auto" style="width: 50px; height: 3px; border-radius: 2px;"></div>
            </div>

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-body p-5">
                    <form asp-action="Guardar" method="post" enctype="multipart/form-data">
                        <input asp-for="Id" type="hidden" />

                        <div class="form-floating mb-4">
                            <input asp-for="Nombre" class="form-control rounded-3" placeholder="Nombre del lote" required />
                            <label class="text-muted">Nombre del Lote</label>
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-muted fw-bold small ms-1">Galería de Imágenes (Máx 4)</label>
                            <div class="upload-area p-4 border border-2 border-dashed rounded-4 text-center" style="background: #fdfdf5; border-color: #d4e0d4;">
                                <i class="fa-solid fa-cloud-arrow-up fa-2x text-success mb-3"></i>
                                <input asp-for="ArchivosFotos" type="file" class="form-control bg-transparent border-0" multiple accept="image/*" />
                                <p class="text-muted small mt-2">Arrastra tus fotos o haz clic para seleccionar</p>
                            </div>
                        </div>

                        <div class="d-flex gap-3 mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary flex-grow-1 rounded-3 py-3 fw-bold">Volver</a>
                            <button type="submit" class="btn btn-success flex-grow-1 rounded-3 py-3 fw-bold shadow-sm" style="background: #1a3c1a;">
                                Guardar Cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus {
        border-color: #1a3c1a;
        box-shadow: 0 0 0 0.25rem rgba(26, 60, 26, 0.15);
    }

    .upload-area {
        transition: 0.3s;
        cursor: pointer;
    }

        .upload-area:hover {
            background: #f4f9f4 !important;
            border-color: #1a3c1a !important;
        }
</style>
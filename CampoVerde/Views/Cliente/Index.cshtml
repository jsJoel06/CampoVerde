@model IEnumerable<CampoVerde.Models.Cliente>

@{
    ViewData["Title"] = "Gestión de Clientes";
    var totalClientes = Model.Count();
    var clientesActivos = Model.Count(x => x.Activo);
}


<div class="container py-5">


    <!-- Encabezado -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold text-success mb-1">
                <i class="fa-solid fa-building me-2"></i>
                Clientes CampoVerde
            </h2>

            <p class="text-muted mb-0">
                Administra las fincas y empresas con licencia activa
            </p>

        </div>


        <a asp-action="Create"
           class="btn btn-success rounded-pill px-4 shadow-sm mt-3 mt-md-0">

            <i class="fa-solid fa-plus me-2"></i>
            Nueva Licencia

        </a>

    </div>




    <!-- Estadísticas -->

    <div class="row mb-4">


        <div class="col-md-4">

            <div class="card border-0 shadow-sm rounded-4 p-3">

                <div class="d-flex align-items-center">


                    <div class="icon-box bg-success">

                        <i class="fa-solid fa-users"></i>

                    </div>


                    <div>

                        <small class="text-muted">
                            Clientes registrados
                        </small>

                        <h3 class="fw-bold mb-0">
                            @totalClientes
                        </h3>

                    </div>


                </div>

            </div>

        </div>




        <div class="col-md-4">

            <div class="card border-0 shadow-sm rounded-4 p-3">

                <div class="d-flex align-items-center">


                    <div class="icon-box bg-primary">

                        <i class="fa-solid fa-circle-check"></i>

                    </div>


                    <div>

                        <small class="text-muted">
                            Licencias activas
                        </small>

                        <h3 class="fw-bold mb-0">
                            @clientesActivos
                        </h3>

                    </div>


                </div>

            </div>

        </div>



    </div>






    <!-- Tabla -->


    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">


        <div class="card-header bg-success text-white py-3">


            <h5 class="mb-0 fw-bold">

                <i class="fa-solid fa-address-book me-2"></i>

                Empresas con licencia

            </h5>


        </div>




        <div class="table-responsive">


            <table class="table table-hover align-middle mb-0">


                <thead class="table-light">


                    <tr>


                        <th class="ps-4">
                            Cliente
                        </th>


                        <th>
                            Plan
                        </th>


                        <th>
                            Contacto
                        </th>


                        <th>
                            Vencimiento
                        </th>


                        <th>
                            Estado
                        </th>


                        <th class="text-center">
                            Acciones
                        </th>


                    </tr>


                </thead>



                <tbody>


                    @foreach (var item in Model)
                    {


                        <tr>


                            <!-- Cliente -->

                            <td class="ps-4">


                                <div class="d-flex align-items-center">


                                    <div class="avatar me-3">

                                        <i class="fa-solid fa-building"></i>

                                    </div>



                                    <div>

                                        <h6 class="fw-bold mb-0">
                                            @item.NombreEmpresa
                                        </h6>


                                        <small class="text-muted">
                                            @item.Nombre
                                        </small>


                                    </div>



                                </div>


                            </td>





                            <!-- Plan -->

                            <td>


                                <span class="badge bg-success rounded-pill px-3 py-2">

                                    <i class="fa-solid fa-crown me-1"></i>

                                    @item.Plan

                                </span>


                            </td>





                            <!-- Contacto -->

                            <td>


                                <div>

                                    <i class="fa-solid fa-phone text-success me-1"></i>

                                    @item.Telefono

                                </div>


                                <small class="text-muted">

                                    <i class="fa-solid fa-envelope me-1"></i>

                                    @item.Email

                                </small>


                            </td>






                            <!-- Fecha -->

                            <td>


                                @if (item.FechaVencimiento != null)
                                {

                                    @item.FechaVencimiento.Value.ToString("dd/MM/yyyy")

                                }
                                else
                                {
                                    <span class="text-muted">
                                        Sin fecha
                                    </span>
                                }


                            </td>






                            <!-- Estado -->


                            <td>


                                @if (item.Activo)
                                {

                                    <span class="badge bg-success rounded-pill">
                                        Activo
                                    </span>

                                }
                                else
                                {

                                    <span class="badge bg-danger rounded-pill">
                                        Inactivo
                                    </span>

                                }


                            </td>


                            <!-- Acciones -->

                            <td class="text-center">


                                <!-- Crear usuario administrador -->
                                <a asp-controller="Auth"
                                   asp-action="Register"
                                   asp-route-clienteId="@item.Id"
                                   class="btn btn-sm btn-outline-success rounded-circle me-2"
                                   title="Crear usuario">

                                    <i class="fa-solid fa-user-plus"></i>

                                </a>




                                <!-- Editar cliente -->

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary rounded-circle me-2"
                                   title="Editar licencia">

                                    <i class="fa-solid fa-pen"></i>

                                </a>





                                <!-- Eliminar cliente -->

                                <form asp-action="Delete"
                                      asp-route-id="@item.Id"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('¿Eliminar esta licencia?');">


                                    <button class="btn btn-sm btn-outline-danger rounded-circle"
                                            title="Eliminar">

                                        <i class="fa-solid fa-trash"></i>

                                    </button>


                                </form>


                            </td>

                        </tr>


                    }


                </tbody>



            </table>


        </div>


    </div>


</div>




<style>

    .icon-box {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        margin-right: 15px;
    }


    .avatar {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        background: #198754;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
    }


    .table tbody tr {
        transition: .2s;
    }


        .table tbody tr:hover {
            background: #f5fff8;
            transform: scale(1.005);
        }

</style>
@model IEnumerable<CampoVerde.Models.Notificacion>

<style>
    .dropdown-notif {
        width: 320px;
        border-radius: 20px;
        border: 1px solid #d4e0d4;
        background-color: #fdfdf5;
        box-shadow: 0 10px 30px rgba(74, 124, 74, 0.15);
    }

    .notif-item {
        font-size: 0.85em;
        color: #2d3a2d;
        border-bottom: 1px solid #eaf2e9;
        white-space: normal;
        transition: background 0.2s;
    }

        .notif-item:hover {
            background-color: #eaf2e9;
        }

    .punto-verde {
        position: absolute;
        top: 8px;
        right: 2px;
        width: 10px;
        height: 10px;
        background-color: #2ec4b6; /* Punto verde agua/esmeralda moderno */
        border: 2px solid #fff;
    }
</style>

<li class="nav-item dropdown me-3 position-relative">
    <a class="nav-link dropdown-toggle no-caret" href="#" id="notifDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="fa-solid fa-bell" style="color: #3d663d; font-size: 1.2rem;"></i>

        <!-- Si hay notificaciones sin leer, aparece el punto verde -->
        @if (ViewBag.ContadorSinLeer > 0)
        {
            <span class="punto-verde rounded-circle"></span>
        }
    </a>

    <ul class="dropdown-menu dropdown-menu-end dropdown-notif p-2" aria-labelledby="notifDropdown">
        <li class="px-3 py-2 fw-bold text-success border-bottom mb-1" style="font-family: 'Georgia', serif;">
            Actividad Reciente
        </li>

        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <li>
                    <a class="dropdown-item notif-item p-2 rounded-3" href="#">
                        <div class="d-flex align-items-start">
                            <i class="fa-solid fa-circle-check text-success mt-1 me-2" style="font-size: 0.8em;"></i>
                            <div>
                                <div>@item.Mensaje</div>
                                <small class="text-secondary" style="font-size: 0.75em;">@item.Fecha.ToShortTimeString()</small>
                            </div>
                        </div>
                    </a>
                </li>
            }
        }
        else
        {
            <li class="text-center py-3 text-muted small">No hay actividades nuevas.</li>
        }
    </ul>
</li>
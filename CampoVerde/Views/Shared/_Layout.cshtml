<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@($"{ViewData["Title"]} - CampoVerde")</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { background-color: #f8f9fa; font-family: 'Segoe UI', sans-serif; }
        .navbar { background: #fff; border-bottom: 2px solid #e9ecef; }
        .nav-link { color: #495057 !important; font-weight: 500; }
        .nav-link:hover { color: #2e7d32 !important; }
        .brand-text { font-size: 20px; font-weight: bold; line-height: 1; }
        .brand-text span { color: #2e7d32; }
        
        /* Ajuste para móvil */
        @@media (max-width: 991px) {
            .navbar-collapse { background: #fff; padding: 15px; border-radius: 15px; margin-top: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
            .navbar-nav { margin-left: 0 !important; }
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light mb-4">
            <div class="container-fluid">
                <!-- Logo -->
                <div class="d-flex align-items-center">
                    <img src="~/img/vaca.jpg" alt="Logo" class="me-3" style="width: 45px; height: 45px; object-fit: cover; border-radius: 50%;">
                    <a class="navbar-brand text-dark d-flex flex-column" asp-controller="Home" asp-action="Index" style="text-decoration: none;">
                        <div class="brand-text">Campo<span>Verde</span></div>
                    </a>
                </div>

                <!-- Botón Hamburguesa -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Menú -->
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav ms-lg-5">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Animal" asp-action="Index">Mis Animales</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Vacuna" asp-action="Index">Vacunas</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Alimentos" asp-action="Index">Inventario</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Privacy">Reportes</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Dashboard">Dashboard</a></li>
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item me-3">
                            <a class="nav-link" asp-controller="Vacuna" asp-action="ProximasVacunas">
                                <i class="fa-solid fa-bell"></i>
                                <span class="badge bg-danger rounded-pill" style="font-size: 0.6rem; vertical-align: top;">!</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Usuario" asp-action="Perfil" title="Mi Perfil">
                                <i class="fa-solid fa-user-circle fa-lg"></i>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
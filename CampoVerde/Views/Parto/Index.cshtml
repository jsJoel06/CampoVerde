@model IEnumerable<CampoVerde.Models.Parto>

@{
    ViewData["Title"] = "Partos";
}

<style>

    body {
        background: #eef5ef;
    }

    .stat-card {
        border: none;
        border-radius: 20px;
        background: linear-gradient(135deg,#2e7d32,#43a047);
        color: white;
    }

    .parto-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        transition: .3s;
        box-shadow: 0 10px 25px rgba(0,0,0,.08);
    }

        .parto-card:hover {
            transform: translateY(-5px);
        }

    .badge-estado {
        font-size: .9rem;
        padding: 8px 14px;
        border-radius: 20px;
    }

</style>

<div class="container py-5">

    <!-- ENCABEZADO -->

    <div class="row mb-5">

        <div class="col-md-8">

            <h1 class="fw-bold text-success">
                🍼 Gestión de Partos
            </h1>

            <p class="text-muted">
                Registro y control de los nacimientos del ganado.
            </p>

        </div>

        <div class="col-md-4 text-end">

            <a asp-action="Historial" class="btn btn-outline-success btn-lg">
                <i class="bi bi-clock-history"></i>
                Historial
            </a>

            <a asp-action="Create" class="btn btn-success btn-lg">
                <i class="bi bi-plus-circle-fill"></i>
                Nuevo Parto
            </a>

        </div>

    </div>

    <!-- ESTADÍSTICAS -->

    <div class="row g-4 mb-5">

        <div class="col-md-3">

            <div class="card stat-card">

                <div class="card-body text-center">

                    <i class="bi bi-heart-fill display-4"></i>

                    <h5 class="mt-3">
                        Total Partos
                    </h5>

                    <h2>@ViewBag.TotalPartos</h2>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card stat-card">

                <div class="card-body text-center">

                    <i class="bi bi-gender-male display-4"></i>

                    <h5 class="mt-3">
                        Machos
                    </h5>

                    <h2>@ViewBag.TotalMachos</h2>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card stat-card">

                <div class="card-body text-center">

                    <i class="bi bi-gender-female display-4"></i>

                    <h5 class="mt-3">
                        Hembras
                    </h5>

                    <h2>@ViewBag.TotalHembras</h2>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card stat-card">

                <div class="card-body text-center">

                    <i class="bi bi-calendar-check display-4"></i>

                    <h5 class="mt-3">
                        Hoy
                    </h5>

                    <h2>@ViewBag.PartosHoy</h2>

                </div>

            </div>

        </div>

    </div>

    <!-- TARJETAS -->

    <div class="row g-4">

        @foreach (var item in Model)
        {

            <div class="col-md-6 col-lg-4">

                <div class="card parto-card h-100">

                    <div class="card-header bg-success text-white">

                        <h4 class="mb-1">

                            🐄 @item.Animal?.nombre

                        </h4>

                        <small>

                            @item.FechaParto.ToString("dd/MM/yyyy")

                        </small>

                    </div>

                    <div class="card-body">

                        <p>

                            <strong>Sexo de la cría:</strong>

                            @if (item.SexoCria == "Macho")
                            {
                                <span class="badge bg-primary">
                                    ♂ Macho
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    ♀ Hembra
                                </span>
                            }

                        </p>

                        <p>

                            <strong>Peso:</strong>

                            @item.PesoCria kg

                        </p>

                        <p>

                            <strong>Estado:</strong>

                            <span class="badge bg-success badge-estado">

                                @item.EstadoCria

                            </span>

                        </p>

                        @if (!string.IsNullOrWhiteSpace(item.Observaciones))
                        {

                            <hr>

                            <small class="text-muted">

                                Observaciones

                            </small>

                            <p>

                                @item.Observaciones

                            </p>

                        }

                    </div>

                    <div class="card-footer bg-white border-0">

                        <div class="d-grid gap-2">

                            <a asp-action="Details"
                               asp-route-id="@item.IdParto"
                               class="btn btn-outline-primary">

                                <i class="bi bi-eye"></i>

                                Detalles

                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@item.IdParto"
                               class="btn btn-outline-success">

                                <i class="bi bi-pencil-square"></i>

                                Editar

                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.IdParto"
                               class="btn btn-outline-danger">

                                <i class="bi bi-trash"></i>

                                Eliminar

                            </a>

                        </div>

                    </div>

                </div>

            </div>

        }

    </div>

</div>
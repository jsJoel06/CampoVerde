

@{
    ViewData["Title"] = "Detalle del Parto";
}

<style>
    body {
        background-color: #eaf2e9;
        font-family: 'Segoe UI', sans-serif;
    }

    .card-ganaderia {
        background-color: #fdfdf5;
        border-radius: 30px;
        box-shadow: 0 10px 30px rgba(74, 124, 74, 0.1);
        padding: 45px;
        border: 1px solid #d4e0d4;
    }

    h2 {
        font-family: 'Georgia', serif;
        color: #1a3c1a;
        font-weight: 700;
        margin-bottom: 25px;
    }

    .info-label {
        color: #5c9a5c;
        font-weight: 600;
        font-size: 0.9rem;
        text-transform: uppercase;
    }

    .info-value {
        color: #2d3a2d;
        font-size: 1.2rem;
        font-weight: 500;
        margin-bottom: 20px;
    }

    .divider {
        height: 1px;
        background-color: #d4e0d4;
        margin: 20px 0;
    }

    .btn-volver {
        background-color: #d1e0d1;
        color: #2d4d2d;
        border-radius: 50px;
        padding: 10px 25px;
        text-decoration: none;
        font-weight: bold;
    }

    .btn-editar {
        background: linear-gradient(135deg, #5c9a5c, #3d663d);
        color: white;
        border-radius: 50px;
        padding: 10px 30px;
        text-decoration: none;
    }
</style>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card-ganaderia">
                <h2><i class="bi bi-info-circle"></i> Detalles del Parto</h2>

                <div class="row">
                    <div class="col-6">
                        <div class="info-label">Fecha de Parto</div>
                        <div class="info-value">@Model.FechaParto.ToString("dd MMMM yyyy")</div>
                    </div>
                    <div class="col-6">
                        <div class="info-label">Madre (Vaca)</div>
                        <div class="info-value">@Model.Animal?.nombre</div>
                    </div>
                </div>

                <div class="divider"></div>

                <h5 class="text-success mb-3"><i class="bi bi-star"></i> Datos de la Cría</h5>

                <div class="row">
                    <div class="col-6">
                        <div class="info-label">Nombre</div>
                        <div class="info-value">@Model.NombreCria</div>
                    </div>
                    <div class="col-6">
                        <div class="info-label">Código</div>
                        <div class="info-value">@Model.CodigoCria</div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-6">
                        <div class="info-label">Sexo</div>
                        <div class="info-value">@Model.SexoCria</div>
                    </div>
                    <div class="col-6">
                        <div class="info-label">Peso al Nacer</div>
                        <div class="info-value">@Model.PesoCria kg</div>
                    </div>
                </div>

                <div class="mt-4 d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-volver">
                        <i class="bi bi-arrow-left"></i> Volver
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model.IdParto" class="btn btn-editar">
                        <i class="bi bi-pencil"></i> Editar
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>